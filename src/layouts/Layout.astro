---
/**
 * Layout — the shell every page inherits.
 *
 * Nav is a child component. Footer holds the ABM wordmark.
 * A fixed top gradient visor protects nav legibility when
 * photographic content scrolls beneath it.
 */
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title       = 'Adeyinka Maddy',
  description = 'Adeyinka Maddy — Creative. New York.',
} = Astro.props;

const pageTitle    = 'Adeyinka Maddy — Creative. New York.';
const ogTitle      = 'Adeyinka Maddy — Creative. New York.';
const ogDescription = description;
const canonicalURL  = new URL(Astro.url.pathname, 'https://abmwork.netlify.app');
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={ogDescription} />
    <title>{pageTitle}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph (Facebook, LinkedIn, iMessage, Slack, etc.) -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="Adeyinka Maddy" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image"       content="https://abmwork.netlify.app/og-image.jpg" />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"   content="Adeyinka Maddy — Creative. New York." />

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image"       content="https://abmwork.netlify.app/og-image.jpg" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!--
      Instrument Serif — display / hero
      Only italics are used in the design.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Custom cursor — logo mark on hover over clickable elements -->
    <div id="cursor" aria-hidden="true">
      <svg viewBox="190 147 232 498" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="306" cy="263" r="101" stroke="currentColor" stroke-width="28"/>
        <circle cx="306" cy="395" r="101" stroke="currentColor" stroke-width="28"/>
        <circle cx="306" cy="529" r="101" stroke="currentColor" stroke-width="28"/>
      </svg>
    </div>

    <!--
      Fixed top gradient visor — renders below the nav (z-index: 100)
      but above page content. Keeps the nav links legible when
      full-bleed images scroll underneath.
      Intentionally very subtle so it doesn't crop the photograph.
    -->
    <div class="nav-visor" aria-hidden="true"></div>

    <Navigation />

    <main id="main-content">
      <slot />
    </main>

    <!--
      ABM wordmark — appears only at the very bottom of every page.
      Times New Roman, barely visible, letter-spaced.
    -->
    <footer class="site-footer" aria-label="Site footer">
      <span class="abm">ABM</span>
    </footer>

    <script>
      // Custom cursor — only on fine-pointer (mouse) devices
      if (window.matchMedia('(pointer: fine)').matches) {
        const cursor = document.getElementById('cursor')!;
        const CLICKABLE = 'a, button, [role="button"], label[for], select';

        // Track position — set directly for zero lag
        document.addEventListener('mousemove', (e) => {
          cursor.style.left = e.clientX + 'px';
          cursor.style.top  = e.clientY + 'px';
        }, { passive: true });

        // Show logo when over a clickable element
        document.addEventListener('mouseover', (e) => {
          const over = (e.target as Element).closest(CLICKABLE);
          cursor.classList.toggle('active', !!over);
        });

        // Hide when mouse leaves the window entirely
        document.addEventListener('mouseleave', () => {
          cursor.classList.remove('active');
        });
      }
    </script>
  </body>
</html>

<style is:global>
  /* ─── Hard reset ─── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    color-scheme: dark;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    background: #000;
    color: #fff;
    font-family: 'Times New Roman', Times, serif;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  main {
    flex: 1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img, video {
    display: block;
    max-width: 100%;
  }

  ::selection {
    background: #fff;
    color: #000;
  }
</style>

<style>
  /* ─── Custom cursor ─── */
  #cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 22px;
    height: auto;
    pointer-events: none;
    z-index: 99999;
    color: #fff;
    opacity: 0;
    transition: opacity 0.18s ease;
    /* Offset so the top circle aligns with the pointer tip */
    transform: translate(-50%, -18%);
    will-change: transform, left, top;
  }

  #cursor svg {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 1px 4px rgba(0,0,0,0.5));
  }

  #cursor.active { opacity: 1; }

  /* Hide default cursor on clickable elements (fine-pointer devices only) */
  @media (pointer: fine) {
    a, button, [role="button"], label[for], select {
      cursor: none;
    }
  }

  /* ─── Nav visor ─── */
  /*
   * A fixed, non-interactive gradient that fades from
   * near-black at the very top to transparent.
   * Ensures white nav text reads cleanly over bright images.
   * Subtle enough that it won't crop the top of a photograph.
   */
  .nav-visor {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    height: 110px;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.52) 0%,
      rgba(0, 0, 0, 0.18) 55%,
      rgba(0, 0, 0, 0) 100%
    );
    z-index: 150; /* above content, below nav (200) */
    pointer-events: none;
  }

  /* ─── Footer / ABM mark ─── */
  .site-footer {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1.75rem 1.5rem 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: auto;
  }

  .abm {
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.75rem; /* slightly bigger */
    letter-spacing: 0.55em;
    /* Compensate for letter-spacing optical shift */
    padding-left: 0.55em;
    color: #fff;
    text-transform: uppercase;
    user-select: none;
  }
</style>
