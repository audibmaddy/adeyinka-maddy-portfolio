---
/**
 * Layout — the shell every page inherits.
 *
 * Nav is a child component. Footer holds the ABM wordmark.
 * A fixed top gradient visor protects nav legibility when
 * photographic content scrolls beneath it.
 */
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title       = 'Adeyinka Maddy',
  description = 'Adeyinka Maddy — Creative. New York.',
} = Astro.props;

const pageTitle    = 'Adeyinka Maddy — Creative. New York.';
const ogTitle      = 'Adeyinka Maddy — Creative. New York.';
const ogDescription = description;
const canonicalURL  = new URL(Astro.url.pathname, 'https://abmwork.netlify.app');
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={ogDescription} />
    <title>{pageTitle}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph (Facebook, LinkedIn, iMessage, Slack, etc.) -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="Adeyinka Maddy" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image"       content="https://abmwork.netlify.app/og-image.jpg" />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"   content="Adeyinka Maddy — Creative. New York." />

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image"       content="https://abmwork.netlify.app/og-image.jpg" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!--
      Instrument Serif — display / hero
      Only italics are used in the design.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Custom cursor — logo mark on hover over clickable elements -->
    <div id="cursor" aria-hidden="true">
      <svg viewBox="190 147 232 498" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="306" cy="263" r="101" stroke="currentColor" stroke-width="28"/>
        <circle cx="306" cy="395" r="101" stroke="currentColor" stroke-width="28"/>
        <circle cx="306" cy="529" r="101" stroke="currentColor" stroke-width="28"/>
      </svg>
    </div>

    <!--
      Fixed top gradient visor — renders below the nav (z-index: 100)
      but above page content. Keeps the nav links legible when
      full-bleed images scroll underneath.
      Intentionally very subtle so it doesn't crop the photograph.
    -->
    <div class="nav-visor" aria-hidden="true"></div>

    <Navigation />

    <main id="main-content">
      <slot />
    </main>

    <!--
      ABM wordmark — appears only at the very bottom of every page.
      Times New Roman, barely visible, letter-spaced.
    -->
    <footer class="site-footer" aria-label="Site footer">
      <!-- Wordmark SVG — cropped viewBox isolates the letterforms -->
      <svg
        viewBox="163 356 282 90"
        xmlns="http://www.w3.org/2000/svg"
        class="wordmark-svg"
        fill="white"
        aria-label="ABM"
        focusable="false"
      >
        <defs>
          <clipPath id="wm-clip"><rect x="0" width="280" y="0" height="168"/></clipPath>
        </defs>
        <g transform="matrix(1,0,0,1,166,312)">
          <g clip-path="url(#wm-clip)">
            <g fill="#ffffff" fill-opacity="1">
              <g transform="translate(0.154086,130.624506)"><g><path d="M 56.171875 -27.21875 L 24.703125 -27.21875 L 19.1875 -14.390625 C 17.820312 -11.234375 17.140625 -8.875 17.140625 -7.3125 C 17.140625 -6.070312 17.726562 -4.984375 18.90625 -4.046875 C 20.09375 -3.109375 22.644531 -2.5 26.5625 -2.21875 L 26.5625 0 L 0.953125 0 L 0.953125 -2.21875 C 4.347656 -2.8125 6.546875 -3.59375 7.546875 -4.5625 C 9.585938 -6.476562 11.847656 -10.375 14.328125 -16.25 L 42.921875 -83.140625 L 45.015625 -83.140625 L 73.3125 -15.53125 C 75.59375 -10.09375 77.660156 -6.5625 79.515625 -4.9375 C 81.367188 -3.320312 83.957031 -2.414062 87.28125 -2.21875 L 87.28125 0 L 55.203125 0 L 55.203125 -2.21875 C 58.441406 -2.375 60.628906 -2.910156 61.765625 -3.828125 C 62.910156 -4.753906 63.484375 -5.875 63.484375 -7.1875 C 63.484375 -8.945312 62.679688 -11.726562 61.078125 -15.53125 Z M 54.484375 -31.65625 L 40.703125 -64.5 L 26.5625 -31.65625 Z"/></g></g>
              <g transform="translate(88.806148,130.624506)"><g><path d="M 56.703125 -41.484375 C 62.335938 -40.285156 66.554688 -38.367188 69.359375 -35.734375 C 73.234375 -32.054688 75.171875 -27.554688 75.171875 -22.234375 C 75.171875 -18.203125 73.890625 -14.335938 71.328125 -10.640625 C 68.773438 -6.941406 65.269531 -4.242188 60.8125 -2.546875 C 56.351562 -0.847656 49.550781 0 40.40625 0 L 2.03125 0 L 2.03125 -2.21875 L 5.09375 -2.21875 C 8.488281 -2.21875 10.925781 -3.296875 12.40625 -5.453125 C 13.320312 -6.847656 13.78125 -9.828125 13.78125 -14.390625 L 13.78125 -66.890625 C 13.78125 -71.929688 13.203125 -75.109375 12.046875 -76.421875 C 10.492188 -78.179688 8.175781 -79.0625 5.09375 -79.0625 L 2.03125 -79.0625 L 2.03125 -81.28125 L 37.171875 -81.28125 C 43.722656 -81.28125 48.976562 -80.800781 52.9375 -79.84375 C 58.925781 -78.40625 63.5 -75.859375 66.65625 -72.203125 C 69.8125 -68.546875 71.390625 -64.335938 71.390625 -59.578125 C 71.390625 -55.503906 70.148438 -51.859375 67.671875 -48.640625 C 65.191406 -45.421875 61.535156 -43.035156 56.703125 -41.484375 Z M 25.296875 -44.71875 C 26.773438 -44.4375 28.460938 -44.222656 30.359375 -44.078125 C 32.253906 -43.941406 34.34375 -43.875 36.625 -43.875 C 42.457031 -43.875 46.84375 -44.503906 49.78125 -45.765625 C 52.71875 -47.023438 54.960938 -48.953125 56.515625 -51.546875 C 58.078125 -54.148438 58.859375 -56.988281 58.859375 -60.0625 C 58.859375 -64.820312 56.921875 -68.878906 53.046875 -72.234375 C 49.171875 -75.585938 43.519531 -77.265625 36.09375 -77.265625 C 32.09375 -77.265625 28.492188 -76.828125 25.296875 -75.953125 Z M 25.296875 -5.875 C 29.929688 -4.789062 34.507812 -4.25 39.03125 -4.25 C 46.257812 -4.25 51.769531 -5.878906 55.5625 -9.140625 C 59.363281 -12.398438 61.265625 -16.425781 61.265625 -21.21875 C 61.265625 -24.375 60.40625 -27.410156 58.6875 -30.328125 C 56.96875 -33.242188 54.171875 -35.539062 50.296875 -37.21875 C 46.421875 -38.90625 41.625 -39.75 35.90625 -39.75 C 33.425781 -39.75 31.304688 -39.707031 29.546875 -39.625 C 27.796875 -39.539062 26.378906 -39.398438 25.296875 -39.203125 Z"/></g></g>
              <g transform="translate(170.68493,130.624506)"><g><path d="M 50.234375 0 L 18.828125 -68.390625 L 18.828125 -14.09375 C 18.828125 -9.09375 19.363281 -5.972656 20.4375 -4.734375 C 21.914062 -3.054688 24.253906 -2.21875 27.453125 -2.21875 L 30.328125 -2.21875 L 30.328125 0 L 2.03125 0 L 2.03125 -2.21875 L 4.921875 -2.21875 C 8.359375 -2.21875 10.796875 -3.253906 12.234375 -5.328125 C 13.109375 -6.609375 13.546875 -9.53125 13.546875 -14.09375 L 13.546875 -67.203125 C 13.546875 -70.796875 13.144531 -73.390625 12.34375 -74.984375 C 11.789062 -76.148438 10.765625 -77.117188 9.265625 -77.890625 C 7.765625 -78.671875 5.351562 -79.0625 2.03125 -79.0625 L 2.03125 -81.28125 L 25.0625 -81.28125 L 54.546875 -17.6875 L 83.5625 -81.28125 L 106.578125 -81.28125 L 106.578125 -79.0625 L 103.765625 -79.0625 C 100.285156 -79.0625 97.828125 -78.023438 96.390625 -75.953125 C 95.515625 -74.671875 95.078125 -71.753906 95.078125 -67.203125 L 95.078125 -14.09375 C 95.078125 -9.09375 95.632812 -5.972656 96.75 -4.734375 C 98.226562 -3.054688 100.566406 -2.21875 103.765625 -2.21875 L 106.578125 -2.21875 L 106.578125 0 L 72.046875 0 L 72.046875 -2.21875 L 74.9375 -2.21875 C 78.40625 -2.21875 80.84375 -3.253906 82.25 -5.328125 C 83.125 -6.609375 83.5625 -9.53125 83.5625 -14.09375 L 83.5625 -68.390625 L 52.21875 0 Z"/></g></g>
            </g>
          </g>
        </g>
      </svg>
    </footer>

    <script>
      // Custom cursor — only on fine-pointer (mouse) devices
      if (window.matchMedia('(pointer: fine)').matches) {
        const cursor = document.getElementById('cursor')!;
        const CLICKABLE = 'a, button, [role="button"], label[for], select';

        // Track position — set directly for zero lag
        document.addEventListener('mousemove', (e) => {
          cursor.style.left = e.clientX + 'px';
          cursor.style.top  = e.clientY + 'px';
        }, { passive: true });

        // Show logo when over a clickable element
        document.addEventListener('mouseover', (e) => {
          const over = (e.target as Element).closest(CLICKABLE);
          cursor.classList.toggle('active', !!over);
        });

        // Hide when mouse leaves the window entirely
        document.addEventListener('mouseleave', () => {
          cursor.classList.remove('active');
        });
      }
    </script>
  </body>
</html>

<style is:global>
  /* ─── Hard reset ─── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    color-scheme: dark;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    background: #000;
    color: #fff;
    font-family: 'Times New Roman', Times, serif;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  main {
    flex: 1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img, video {
    display: block;
    max-width: 100%;
  }

  ::selection {
    background: #fff;
    color: #000;
  }
</style>

<style>
  /* ─── Custom cursor ─── */
  #cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 22px;
    height: auto;
    pointer-events: none;
    z-index: 99999;
    color: #fff;
    opacity: 0;
    transition: opacity 0.18s ease;
    /* Offset so the top circle aligns with the pointer tip */
    transform: translate(-50%, -18%);
    will-change: transform, left, top;
  }

  #cursor svg {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 1px 4px rgba(0,0,0,0.5));
  }

  #cursor.active { opacity: 1; }

  /* Hide default cursor on clickable elements (fine-pointer devices only) */
  @media (pointer: fine) {
    a, button, [role="button"], label[for], select {
      cursor: none;
    }
  }

  /* ─── Nav visor ─── */
  /*
   * A fixed, non-interactive gradient that fades from
   * near-black at the very top to transparent.
   * Ensures white nav text reads cleanly over bright images.
   * Subtle enough that it won't crop the top of a photograph.
   */
  .nav-visor {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    height: 110px;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.52) 0%,
      rgba(0, 0, 0, 0.18) 55%,
      rgba(0, 0, 0, 0) 100%
    );
    z-index: 150; /* above content, below nav (200) */
    pointer-events: none;
  }

  /* ─── Footer / ABM mark ─── */
  .site-footer {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1.75rem 1.5rem 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: auto;
  }

  .wordmark-svg {
    height: 0.85rem;
    width: auto;
    display: block;
    user-select: none;
    opacity: 0.9;
  }
</style>
