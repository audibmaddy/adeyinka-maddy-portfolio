---
/**
 * Layout — the shell every page inherits.
 *
 * Nav is a child component. Footer holds the ABM wordmark.
 * A fixed top gradient visor protects nav legibility when
 * photographic content scrolls beneath it.
 */
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title       = 'Adeyinka Maddy',
  description = 'Adeyinka Maddy — Photographer & Creative Director, New York.',
} = Astro.props;

const pageTitle =
  title === 'Adeyinka Maddy'
    ? 'Adeyinka Maddy'
    : `${title} — Adeyinka Maddy`;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!--
      Instrument Serif — display / hero
      Only italics are used in the design.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!--
      Fixed top gradient visor — renders below the nav (z-index: 100)
      but above page content. Keeps the nav links legible when
      full-bleed images scroll underneath.
      Intentionally very subtle so it doesn't crop the photograph.
    -->
    <div class="nav-visor" aria-hidden="true"></div>

    <Navigation />

    <main id="main-content">
      <slot />
    </main>

    <!--
      ABM wordmark — appears only at the very bottom of every page.
      Times New Roman, barely visible, letter-spaced.
    -->
    <footer class="site-footer" aria-label="Site footer">
      <span class="abm">ABM</span>
    </footer>
  </body>
</html>

<style is:global>
  /* ─── Hard reset ─── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    color-scheme: dark;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    background: #000;
    color: #fff;
    font-family: 'Times New Roman', Times, serif;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  main {
    flex: 1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img, video {
    display: block;
    max-width: 100%;
  }

  ::selection {
    background: #fff;
    color: #000;
  }
</style>

<style>
  /* ─── Nav visor ─── */
  /*
   * A fixed, non-interactive gradient that fades from
   * near-black at the very top to transparent.
   * Ensures white nav text reads cleanly over bright images.
   * Subtle enough that it won't crop the top of a photograph.
   */
  .nav-visor {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    height: 110px;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.52) 0%,
      rgba(0, 0, 0, 0.18) 55%,
      rgba(0, 0, 0, 0) 100%
    );
    z-index: 150; /* above content, below nav (200) */
    pointer-events: none;
  }

  /* ─── Footer / ABM mark ─── */
  .site-footer {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1.75rem 1.5rem 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: auto;
  }

  .abm {
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.5625rem; /* 9px */
    letter-spacing: 0.55em;
    /* Compensate for letter-spacing optical shift */
    padding-left: 0.55em;
    color: rgba(255, 255, 255, 0.18);
    text-transform: uppercase;
    user-select: none;
  }
</style>
