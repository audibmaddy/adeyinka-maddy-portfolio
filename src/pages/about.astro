---
/**
 * About — /about
 *
 * Markov-style scrolling experience:
 * A fixed square portrait stays anchored at the viewport center
 * while all content scrolls freely over it with transparent backgrounds.
 * The footer (from Layout.astro) is overridden to solid black so
 * it covers the photo at the end of the page.
 *
 * Typography:
 *   Europa Grotesk DemBold — structural, uppercase labels/headers
 *   Instrument Serif Italic — personal, flowing text
 */
import Layout from '../layouts/Layout.astro';
import headshot from '../assets/branding/media/headshot.jpg';
---

<Layout
  title="About"
  description="Adeyinka Maddy — Creative based in Queens, NY."
>

  <!-- Fixed portrait — anchored to viewport, never scrolls -->
  <div class="photo-fixed" aria-hidden="true">
    <img src={headshot.src} alt="" />
  </div>

  <!-- All scrolling content sits above the photo -->
  <div class="scroll-content">

    <!-- ═══════════════════════════════════════════════════════════
         1. HERO
    ════════════════════════════════════════════════════════════ -->
    <section class="sect s-hero" aria-label="Introduction">
      <p class="hero-tag">
        <span>Creative</span>
        <span class="sep" aria-hidden="true">/</span>
        <span>Queens, NY</span>
      </p>
      <h1 class="hero-name">
        <span class="n1">Adeyinka</span>
        <span class="n2">Maddy</span>
      </h1>

      <!-- Scroll hint — sits below the name at the bottom of the
           hero viewport. Europa micro-caps label + glowing hairline. -->
      <div class="scroll-hint" aria-hidden="true">
        <span class="scroll-hint-label">Scroll</span>
        <div class="scroll-hint-line"></div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         2. BIO
    ════════════════════════════════════════════════════════════ -->
    <section class="sect s-bio" aria-label="Biography">
      <p class="bio-text">
        <span class="bold">NYC</span>-based,
        <span class="bold">Sacramento</span>-raised.
        A photographer and&nbsp;videographer
        by&nbsp;<span class="bold">practice,</span>
        a filmmaker by&nbsp;<span class="bold">conviction.</span>
        Always in motion.
        Rarely&nbsp;<span class="bold">satisfied.</span>
      </p>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         3. DISCIPLINES
    ════════════════════════════════════════════════════════════ -->
    <section class="sect s-disc" aria-label="Disciplines">
      <p class="sect-label">Disciplines</p>
      <ul class="big-list" role="list">
        <li>Photography</li>
        <li>Videography</li>
        <li>Project Management</li>
        <li>Creative Direction</li>
        <li>Campaign Production</li>
      </ul>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         4. SELECTED CLIENTS
    ════════════════════════════════════════════════════════════ -->
    <section class="sect s-clients" aria-label="Selected Clients">
      <p class="sect-label">Selected Clients</p>
      <ul class="big-list" role="list">
        <li><a href="/projects/the-residency-airbnb">Airbnb</a></li>
        <li><a href="/projects/uber-brief">Uber</a></li>
        <li><a href="/projects/oof-campaign-omnicom">Omnicom Health</a></li>
        <li><a href="/work">Independent</a></li>
      </ul>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         5. CONTACT
    ════════════════════════════════════════════════════════════ -->
    <section class="sect s-contact" aria-label="Contact">
      <ul class="social-list" role="list">
        <li><a href="https://www.instagram.com/audi.abm" target="_blank" rel="noopener noreferrer">Instagram</a></li>
        <li><a href="https://www.linkedin.com/in/adeyinka-maddy-62950320b/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
      </ul>
      <a href="mailto:adeyinkabmaddy@gmail.com" class="contact-detail">adeyinkabmaddy@gmail.com</a>
      <a href="tel:+19163081848" class="contact-detail">916-308-1848</a>
      <p class="contact-location">Queens, New York</p>
    </section>

  </div><!-- /scroll-content -->

</Layout>


<style>

/* ── Type voices ─── */

.eu {
  font-family: 'Europa', 'Arial Black', sans-serif;
  font-weight: 700;
  font-style: normal;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.si {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-weight: 400;
  font-style: italic;
  letter-spacing: -0.02em;
}


/* ── Fixed photo ────────────────────────────────────────────── */

.photo-fixed {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 0;
  width: clamp(160px, 22vw, 260px);
  aspect-ratio: 3 / 4;
  overflow: hidden;
  pointer-events: none;
}

.photo-fixed img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 12%;
  display: block;
  filter: grayscale(25%) contrast(0.95) brightness(0.9);
}


/* ── Scrolling content — sits above photo ───────────────────── */

.scroll-content {
  position: relative;
  z-index: 1;
  text-align: center;
}


/* ── Section base ───────────────────────────────────────────── */

.sect {
  padding: clamp(10rem, 20vh, 18rem) clamp(1.5rem, 6vw, 5rem);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  background: transparent;
}


/* ── 1. HERO ────────────────────────────────────────────────── */

.s-hero {
  position: relative;
  min-height: 100svh;
  justify-content: flex-end;
  padding-bottom: clamp(8rem, 15vh, 14rem);
}


/* ── Scroll hint — Europa caps label + downward glide line ── */

.scroll-hint {
  position: absolute;
  bottom: clamp(2.25rem, 4.5vh, 4rem);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.1rem;
  opacity: 0;
  animation: scrollHintReveal 1.6s cubic-bezier(0.16, 1, 0.3, 1) 1.8s forwards;
  pointer-events: none;
  z-index: 3;
}

.scroll-hint-label {
  font-family: 'Europa', 'Arial Black', sans-serif;
  font-weight: 700;
  font-style: normal;
  text-transform: uppercase;
  letter-spacing: 0.45em;
  font-size: clamp(0.5rem, 0.85vw, 0.625rem);
  color: #fff;
  padding-left: 0.45em;
}

.scroll-hint-line {
  position: relative;
  width: 1px;
  height: clamp(72px, 9vh, 110px);
  overflow: hidden;
  background: rgba(255, 255, 255, 0.12);
}

.scroll-hint-line::before {
  content: '';
  position: absolute;
  top: -100%;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(255, 255, 255, 0.85) 50%,
    transparent 100%
  );
  animation: scrollHintGlide 3.2s cubic-bezier(0.55, 0.05, 0.45, 0.95) infinite;
}

@keyframes scrollHintReveal {
  from { opacity: 0; }
  to   { opacity: 0.8; }
}

@keyframes scrollHintGlide {
  0%   { transform: translateY(0); }
  100% { transform: translateY(200%); }
}

.hero-tag {
  font-family: 'Europa', 'Arial Black', sans-serif;
  font-weight: 700;
  font-style: normal;
  text-transform: uppercase;
  letter-spacing: 0.35em;
  font-size: clamp(0.5rem, 0.9vw, 0.625rem);
  color: #fff;
  padding-left: 0.35em;
  margin-bottom: clamp(1.5rem, 3vh, 3rem);
}

.hero-tag .sep {
  letter-spacing: 0;
  color: rgba(255, 255, 255, 0.15);
  padding: 0 0.8em;
}

.hero-name {
  line-height: 0.88;
}

.hero-name .n1 {
  display: block;
  font-family: 'Europa', 'Arial Black', sans-serif;
  font-weight: 700;
  font-style: normal;
  text-transform: uppercase;
  font-size: clamp(4.5rem, 13vw, 14rem);
  color: #fff;
  letter-spacing: -0.01em;
}

.hero-name .n2 {
  display: block;
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-weight: 400;
  font-style: italic;
  font-size: clamp(4.25rem, 12.5vw, 13.5rem);
  color: #fff;
  letter-spacing: -0.025em;
}


/* ── 2. BIO ─────────────────────────────────────────────────── */

.s-bio {
  padding-top: clamp(6rem, 14vh, 12rem);
  padding-bottom: clamp(8rem, 18vh, 16rem);
}

.bio-text {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-weight: 400;
  font-style: italic;
  font-size: clamp(2rem, 4.5vw, 4.5rem);
  line-height: 1.12;
  letter-spacing: -0.02em;
  color: #fff;
  max-width: 16em;
}

.bio-text .bold {
  font-family: 'Europa', 'Arial Black', sans-serif;
  font-weight: 700;
  font-style: normal;
  letter-spacing: -0.01em;
  font-size: 0.88em;
  text-transform: uppercase;
  color: #fff;
}


/* ── 3 & 4. DISCIPLINES / CLIENTS ───────────────────────────── */

.sect-label {
  font-family: 'Europa', 'Arial Black', sans-serif;
  font-weight: 700;
  font-style: normal;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-size: clamp(0.5rem, 1vw, 0.65rem);
  color: #fff;
  padding-left: 0.1em;
  margin-bottom: clamp(2.5rem, 5vh, 5rem);
}

.big-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.08em;
}

.big-list li {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-weight: 400;
  font-style: italic;
  font-size: clamp(2.25rem, 5.5vw, 6rem);
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: #fff;
  transition: color 0.2s ease;
}

.big-list li a {
  color: inherit;
  transition: color 0.2s ease;
}

.big-list li a:hover {
  color: rgba(255, 255, 255, 0.65);
}


/* ── 5. CONTACT ─────────────────────────────────────────────── */

.s-contact {
  gap: 0;
}

.social-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.05em;
  margin-bottom: clamp(3.5rem, 8vh, 8rem);
}

.social-list li a {
  font-family: 'Europa', 'Arial Black', sans-serif;
  font-weight: 700;
  font-style: normal;
  text-transform: uppercase;
  font-size: clamp(3rem, 7.5vw, 8rem);
  letter-spacing: -0.01em;
  color: #fff;
  line-height: 1.0;
  transition: color 0.2s ease;
}

.social-list li a:hover {
  color: rgba(255, 255, 255, 0.65);
}

.contact-detail {
  display: block;
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-weight: 400;
  font-style: italic;
  font-size: clamp(1.5rem, 3.5vw, 3.5rem);
  letter-spacing: -0.01em;
  color: #fff;
  line-height: 1.3;
  transition: color 0.2s ease;
  white-space: nowrap;
}

.contact-detail:hover {
  color: rgba(255, 255, 255, 0.65);
}

.contact-detail + .contact-detail {
  margin-top: 0.2em;
}

.contact-location {
  margin-top: clamp(3rem, 6vh, 6rem);
  font-family: 'Europa', 'Arial Black', sans-serif;
  font-weight: 700;
  font-style: normal;
  text-transform: uppercase;
  letter-spacing: 0.35em;
  font-size: clamp(0.5rem, 0.9vw, 0.625rem);
  color: #fff;
  padding-left: 0.35em;
}


/* ── Footer override — must cover the fixed photo ───────────── */
/* Applied globally so Layout.astro's footer gets solid black   */

:global(.site-footer) {
  position: relative !important;
  z-index: 2 !important;
  background: #000 !important;
}


/* ── Mobile ─────────────────────────────────────────────────── */

@media (max-width: 639px) {
  .hero-name .n1    { font-size: clamp(2.25rem, 15vw, 4rem); }
  .hero-name .n2    { font-size: clamp(2rem, 14vw, 3.75rem); }
  .bio-text         { font-size: clamp(1.5rem, 7vw, 2.5rem); }
  .big-list li      { font-size: clamp(1.5rem, 8vw, 3rem); }
  .social-list li a { font-size: clamp(2rem, 11vw, 4rem); }
  .contact-detail   { font-size: clamp(1rem, 5vw, 1.75rem); white-space: normal; }
  .photo-fixed      { width: clamp(100px, 32vw, 160px); }

  .scroll-hint        { bottom: 2rem; gap: 0.85rem; }
  .scroll-hint-label  { font-size: 0.5rem; letter-spacing: 0.4em; }
  .scroll-hint-line   { height: 64px; }
}

</style>
