---
/**
 * Collection detail page — /work/[slug]
 *
 * Serves selected-works entries where isCollection: true.
 * Currently: Milkshake Collective Volume 1 (/work/milkshake-collective)
 *
 * Layout: full-bleed hero → image sequence.
 * Highlighted images break the grid — full viewport width.
 * Regular images centered at 88vw.
 *
 * References: series/[slug].astro — same image-dominant rhythm.
 */
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// ── Static paths — only collection entries ────────────────────
export async function getStaticPaths() {
  const allSelected = await getCollection('selected-works');
  const collections = allSelected.filter(e => e.data.isCollection);
  return collections.map(entry => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

// ── Image resolution ──────────────────────────────────────────
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  [
    '/src/content/selected-works/*/media/*.jpg',
    '/src/content/selected-works/*/media/*.JPG',
    '/src/content/selected-works/*/media/*.jpeg',
    '/src/content/selected-works/*/media/*.JPEG',
    '/src/content/selected-works/*/media/*.webp',
    '/src/content/selected-works/*/media/*.WEBP',
    '/src/content/selected-works/*/media/*.png',
    '/src/content/selected-works/*/media/*.PNG',
  ],
  { eager: true }
);

const entrySlug = entry.data.slug;

// filename → ImageMetadata for this entry only (case-insensitive)
const mediaMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allImages)) {
  const segments = path.split('/');
  const idx = segments.indexOf('selected-works');
  if (idx !== -1 && segments[idx + 1] === entrySlug && mod.default) {
    const filename = segments[segments.length - 1];
    // Store under both original and lowercase for case-insensitive lookup
    mediaMap[filename] = mod.default;
    mediaMap[filename.toLowerCase()] = mod.default;
  }
}

// Order images, annotate highlighted ones
const order      = entry.data.imageOrder ?? Object.keys(mediaMap);
const highlighted = new Set(entry.data.highlightedImages ?? []);

const images = order
  .map(f => ({
    filename: f,
    src: mediaMap[f] ?? mediaMap[f.toLowerCase()],
    highlighted: highlighted.has(f),
  }))
  .filter(img => Boolean(img.src));

const heroImage      = images[0]?.src;
const sequenceImages = images.slice(1);

const year = entry.data.date.getFullYear();
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
>

<!-- ═══════════════════════════════════════════════════════════
     HERO — full-bleed cover, 100svh
════════════════════════════════════════════════════════════ -->
<section class="hero" aria-label={`${entry.data.title} — cover`}>
  {heroImage && (
    <Image
      src={heroImage}
      alt={`${entry.data.title} — cover photograph`}
      class="hero-img"
      loading="eager"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
    />
  )}

  <div class="hero-label">
    <div class="hero-meta">
      {entry.data.tags.map(tag => (
        <span class="meta-tag">{tag}</span>
      ))}
      <span class="meta-dot" aria-hidden="true">/</span>
      <span class="meta-year">{year}</span>
    </div>
    <h1 class="hero-title">{entry.data.title}</h1>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     IMAGE SEQUENCE
     Regular frames: centered at 88vw.
     Highlighted frames: full-bleed, extra breathing room.
════════════════════════════════════════════════════════════ -->
<section class="sequence" aria-label={`${entry.data.title} — photographs`}>
  {sequenceImages.map((img, i) => (
    <figure
      class:list={['frame', { 'is-highlight': img.highlighted }]}
      aria-label={`${entry.data.title} — image ${i + 2} of ${images.length}`}
    >
      <Image
        src={img.src}
        alt={`${entry.data.title}${img.highlighted ? ' — featured' : ''}`}
        class="seq-img"
        loading="lazy"
        widths={img.highlighted ? [1200, 1800, 2400, 3200] : [800, 1400, 2000]}
        sizes={img.highlighted
          ? '100vw'
          : '(max-width: 767px) 100vw, 88vw'}
      />
    </figure>
  ))}
</section>

<!-- Back link -->
<nav class="back-nav" aria-label="Back to work">
  <a href="/work" class="back-link">
    <span class="back-arrow" aria-hidden="true">&#x2190;</span>
    All Work
  </a>
</nav>

<div class="sequence-rest" aria-hidden="true"></div>

</Layout>


<style>

/* ── HERO ──────────────────────────────────────────────────── */

.hero {
  position: relative;
  height: 100svh;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.75) 0%,
    rgba(0, 0, 0, 0.12) 38%,
    transparent 65%
  );
  pointer-events: none;
}

.hero-label {
  position: absolute;
  bottom: 0;
  inset-inline: 0;
  padding: 2.5rem 2.25rem 3rem;
  z-index: 10;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.meta-tag,
.meta-year {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5625rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.5);
  padding-left: 0.4em;
}

.meta-dot {
  color: rgba(255, 255, 255, 0.22);
  font-size: 0.5rem;
}

.hero-title {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(2.75rem, 6.5vw, 8rem);
  line-height: 0.95;
  letter-spacing: -0.025em;
  color: #fff;
  max-width: 900px;
}


/* ── IMAGE SEQUENCE ────────────────────────────────────────── */

.sequence {
  padding: 0;
  padding-top: clamp(5rem, 8vw, 10rem);
}

/* Regular frame */
.frame {
  margin: 0;
  padding-bottom: clamp(4rem, 6vw, 8rem);
  display: flex;
  justify-content: center;
}

.frame .seq-img {
  display: block;
  width: min(88vw, 1200px);
  height: auto;
}

/* Highlighted / featured frame — full bleed */
.frame.is-highlight {
  padding-top: clamp(4rem, 6vw, 8rem);
  padding-bottom: clamp(7rem, 10vw, 14rem);
  width: 100vw;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
}

.frame.is-highlight .seq-img {
  width: 100%;
  max-width: none;
  height: auto;
}


/* ── BACK LINK ─────────────────────────────────────────────── */

.back-nav {
  display: flex;
  justify-content: center;
  padding: clamp(3rem, 5vw, 6rem) 2.25rem 0;
}

.back-link {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5625rem;
  letter-spacing: 0.38em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.35);
  padding-left: 0.38em;
  transition: color 0.2s ease, gap 0.2s ease;
}

.back-link:hover {
  color: rgba(255, 255, 255, 0.85);
  gap: 1rem;
}

.back-arrow {
  transition: transform 0.2s ease;
  font-size: 0.875rem;
}

.back-link:hover .back-arrow {
  transform: translateX(-3px);
}


/* ── REST ──────────────────────────────────────────────────── */

.sequence-rest {
  height: clamp(5rem, 8vw, 10rem);
}


/* ── MOBILE ─────────────────────────────────────────────────── */

@media (max-width: 639px) {
  .hero-label {
    padding: 2rem 1.25rem 2.5rem;
  }

  .frame .seq-img {
    width: 100vw;
  }

  .back-nav {
    padding-inline: 1.25rem;
  }
}

</style>
