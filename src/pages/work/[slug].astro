---
/**
 * Collection/Gallery detail page — /work/[slug]
 *
 * Serves selected-works entries where:
 *   • isCollection: true  (Milkshake Collective — shows metadata block)
 *   • isGallery: true     (Laundry Day at Webster Hall — pure gallery)
 *
 * Layout: full-bleed hero → optional metadata block → image sequence
 */
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// ── Static paths — collection + gallery entries ───────────────
export async function getStaticPaths() {
  const allSelected = await getCollection('selected-works');
  const eligible = allSelected.filter(e => e.data.isCollection || e.data.isGallery);
  return eligible.map(entry => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

// ── Image resolution ──────────────────────────────────────────
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  [
    '/src/content/selected-works/*/media/*.jpg',
    '/src/content/selected-works/*/media/*.JPG',
    '/src/content/selected-works/*/media/*.jpeg',
    '/src/content/selected-works/*/media/*.JPEG',
    '/src/content/selected-works/*/media/*.webp',
    '/src/content/selected-works/*/media/*.WEBP',
    '/src/content/selected-works/*/media/*.png',
    '/src/content/selected-works/*/media/*.PNG',
  ],
  { eager: true }
);

const entrySlug = entry.data.slug;

const mediaMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allImages)) {
  const segments = path.split('/');
  const idx = segments.indexOf('selected-works');
  if (idx !== -1 && segments[idx + 1] === entrySlug && mod.default) {
    const filename = segments[segments.length - 1];
    mediaMap[filename] = mod.default;
    mediaMap[filename.toLowerCase()] = mod.default;
  }
}

const order       = entry.data.imageOrder ?? Object.keys(mediaMap);
const highlighted = new Set(entry.data.highlightedImages ?? []);

const images = order
  .map(f => ({
    filename: f,
    src: mediaMap[f] ?? mediaMap[f.toLowerCase()],
    highlighted: highlighted.has(f),
  }))
  .filter(img => Boolean(img.src));

const heroImage      = images[0]?.src;
const sequenceImages = images.slice(1);

const year = entry.data.date.getFullYear();

// Metadata — only present for isCollection entries
const hasMetadata = Boolean(entry.data.client || entry.data.role || entry.data.scope);
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
>

<!-- ═══════════════════════════════════════════════════════════
     HERO — full-bleed cover, 100svh
════════════════════════════════════════════════════════════ -->
<section class="hero" aria-label={`${entry.data.title} — cover`}>
  {heroImage && (
    <Image
      src={heroImage}
      alt={`${entry.data.title} — cover photograph`}
      class="hero-img"
      loading="eager"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
    />
  )}

  <div class="hero-label">
    <div class="hero-meta">
      {entry.data.tags.map(tag => (
        <span class="meta-tag">{tag}</span>
      ))}
      <span class="meta-dot" aria-hidden="true">/</span>
      <span class="meta-year">{year}</span>
    </div>
    <h1 class="hero-title">{entry.data.title}</h1>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     METADATA BLOCK (isCollection entries only)
     Client / Role / Location / Scope — henryschwabe register
════════════════════════════════════════════════════════════ -->
{hasMetadata && (
  <section class="meta-block" aria-label="Project information">

    <div class="meta-grid">
      {entry.data.client && (
        <div class="meta-item">
          <span class="meta-label">Client</span>
          <span class="meta-value">{entry.data.client}</span>
        </div>
      )}
      {entry.data.role && (
        <div class="meta-item">
          <span class="meta-label">Role</span>
          <span class="meta-value">{entry.data.role}</span>
        </div>
      )}
      {entry.data.location && (
        <div class="meta-item">
          <span class="meta-label">Location</span>
          <span class="meta-value">{entry.data.location}</span>
        </div>
      )}
      <div class="meta-item">
        <span class="meta-label">Year</span>
        <span class="meta-value">{year}</span>
      </div>
    </div>

    {entry.data.scope && (
      <div class="scope-block">
        <span class="meta-label">Scope</span>
        <p class="scope-text">{entry.data.scope}</p>
      </div>
    )}

  </section>
)}


<!-- ═══════════════════════════════════════════════════════════
     IMAGE SEQUENCE
════════════════════════════════════════════════════════════ -->
<section class="sequence" aria-label={`${entry.data.title} — photographs`}>
  {sequenceImages.map((img, i) => (
    <figure
      class:list={['frame', { 'is-highlight': img.highlighted }]}
      aria-label={`${entry.data.title} — image ${i + 2} of ${images.length}`}
    >
      <Image
        src={img.src}
        alt={`${entry.data.title}${img.highlighted ? ' — featured' : ''}`}
        class="seq-img"
        loading="lazy"
        widths={img.highlighted ? [1200, 1800, 2400, 3200] : [800, 1400, 2000]}
        sizes={img.highlighted ? '100vw' : '(max-width: 767px) 100vw, 88vw'}
      />
    </figure>
  ))}
</section>

<nav class="back-nav" aria-label="Back to work">
  <a href="/work" class="back-link">
    <span class="back-arrow" aria-hidden="true">&#x2190;</span>
    All Work
  </a>
</nav>

<div class="sequence-rest" aria-hidden="true"></div>

</Layout>


<style>

/* ── HERO ──────────────────────────────────────────────────── */

.hero {
  position: relative;
  height: 100svh;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.75) 0%,
    rgba(0, 0, 0, 0.12) 38%,
    transparent 65%
  );
  pointer-events: none;
}

.hero-label {
  position: absolute;
  bottom: 0;
  inset-inline: 0;
  padding: 2.5rem 2.25rem 3rem;
  z-index: 10;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.meta-tag,
.meta-year {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5625rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.68);
  padding-left: 0.4em;
}

.meta-dot {
  color: rgba(255, 255, 255, 0.35);
  font-size: 0.5rem;
}

.hero-title {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(2.75rem, 6.5vw, 8rem);
  line-height: 0.95;
  letter-spacing: -0.025em;
  color: #fff;
  max-width: 900px;
}


/* ── METADATA BLOCK ────────────────────────────────────────── */

.meta-block {
  padding: clamp(4rem, 7vw, 8rem) 2.25rem clamp(3rem, 5vw, 6rem);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2rem clamp(2rem, 4vw, 5rem);
  margin-bottom: 2.5rem;
}

@media (min-width: 640px) {
  .meta-grid {
    grid-template-columns: repeat(4, auto);
    gap: 0;
  }

  .meta-item {
    border-right: 1px solid rgba(255, 255, 255, 0.07);
    padding-right: clamp(2rem, 3vw, 4rem);
  }

  .meta-item:not(:first-child) {
    padding-left: clamp(2rem, 3vw, 4rem);
  }

  .meta-item:last-child {
    border-right: none;
  }
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}

.meta-label {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5rem;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.42);
  padding-left: 0.5em;
}

.meta-value {
  font-family: 'Times New Roman', Times, serif;
  font-size: clamp(0.8125rem, 1vw, 0.9375rem);
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.65);
}

.scope-block {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding-top: 2.5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.scope-text {
  font-family: 'Times New Roman', Times, serif;
  font-size: clamp(0.875rem, 1.1vw, 1rem);
  line-height: 1.85;
  color: rgba(255, 255, 255, 0.55);
  max-width: 680px;
}


/* ── IMAGE SEQUENCE ────────────────────────────────────────── */

.sequence {
  padding: 0;
  padding-top: clamp(5rem, 8vw, 10rem);
}

.frame {
  margin: 0;
  padding-bottom: clamp(4rem, 6vw, 8rem);
  display: flex;
  justify-content: center;
}

.frame .seq-img {
  display: block;
  width: min(88vw, 1200px);
  height: auto;
}

.frame.is-highlight {
  padding-top: clamp(4rem, 6vw, 8rem);
  padding-bottom: clamp(7rem, 10vw, 14rem);
  width: 100vw;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
}

.frame.is-highlight .seq-img {
  width: 100%;
  max-width: none;
  height: auto;
}


/* ── BACK LINK ─────────────────────────────────────────────── */

.back-nav {
  display: flex;
  justify-content: center;
  padding: clamp(3rem, 5vw, 6rem) 2.25rem 0;
}

.back-link {
  display: inline-flex;
  align-items: center;
  gap: 0.625rem;
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5625rem;
  letter-spacing: 0.38em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.55);
  padding-left: 0.38em;
  transition: color 0.2s ease, gap 0.2s ease;
}

.back-link:hover {
  color: rgba(255, 255, 255, 0.85);
  gap: 1rem;
}

.back-arrow {
  transition: transform 0.2s ease;
  font-size: 0.875rem;
}

.back-link:hover .back-arrow {
  transform: translateX(-3px);
}

.sequence-rest {
  height: clamp(5rem, 8vw, 10rem);
}


/* ── MOBILE ─────────────────────────────────────────────────── */

@media (max-width: 639px) {
  .hero-label {
    padding: 2rem 1.25rem 2.5rem;
  }

  .meta-block {
    padding-inline: 1.25rem;
  }

  .frame .seq-img {
    width: 100vw;
  }

  .back-nav {
    padding-inline: 1.25rem;
  }
}

</style>
