---
/**
 * Work index — /work
 *
 * Two filters: "Projects" (default) | "Selected Work"
 *
 * Projects:
 *   • Fixed order: milkshake-collective, third-eye, uber-brief,
 *     sw-reveal, the-residency-airbnb, oof-campaign-omnicom
 *   • Large 2-column grid, prominent cards
 *
 * Selected Work:
 *   • All selected-works items as images (masonry)
 *   • Items with `isGallery: true` are clickable
 *   • Items with `label`/`sublabel` show on hover
 *
 * URL param: /work?tab=selected → opens Selected Work tab
 */
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// ── Content ───────────────────────────────────────────────────
const selectedWorks = await getCollection('selected-works');
const projects      = await getCollection('projects');

const sortedSelected = selectedWorks.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// isCollection entries appear in Projects tab
const collectionsFromSelected = selectedWorks.filter(e => e.data.isCollection);

// ── Cover image resolution ────────────────────────────────────
const selectedCovers = import.meta.glob<{ default: ImageMetadata }>(
  [
    '/src/content/selected-works/*/media/*.jpg',
    '/src/content/selected-works/*/media/*.JPG',
    '/src/content/selected-works/*/media/*.jpeg',
    '/src/content/selected-works/*/media/*.JPEG',
    '/src/content/selected-works/*/media/*.webp',
    '/src/content/selected-works/*/media/*.WEBP',
    '/src/content/selected-works/*/media/*.png',
    '/src/content/selected-works/*/media/*.PNG',
  ],
  { eager: true }
);

const seriesCovers = import.meta.glob<{ default: ImageMetadata }>(
  [
    '/src/content/series/*/media/*.jpg',
    '/src/content/series/*/media/*.JPG',
    '/src/content/series/*/media/*.jpeg',
    '/src/content/series/*/media/*.JPEG',
    '/src/content/series/*/media/*.webp',
    '/src/content/series/*/media/*.WEBP',
    '/src/content/series/*/media/*.png',
    '/src/content/series/*/media/*.PNG',
  ],
  { eager: true }
);

const projectCovers = import.meta.glob<{ default: ImageMetadata }>(
  [
    '/src/content/projects/*/media/*.jpg',
    '/src/content/projects/*/media/*.JPG',
    '/src/content/projects/*/media/*.jpeg',
    '/src/content/projects/*/media/*.JPEG',
    '/src/content/projects/*/media/*.webp',
    '/src/content/projects/*/media/*.WEBP',
    '/src/content/projects/*/media/*.png',
    '/src/content/projects/*/media/*.PNG',
  ],
  { eager: true }
);

function resolveCover(
  slug: string,
  coverPath: string,
  map: Record<string, { default: ImageMetadata }>,
  collection: string
): ImageMetadata | null {
  const filename = coverPath.split('/').pop();
  if (!filename) return null;
  const filenameLower = filename.toLowerCase();
  for (const [path, mod] of Object.entries(map)) {
    const segs = path.split('/');
    const collIdx = segs.findIndex(s => s === collection);
    if (collIdx !== -1 && segs[collIdx + 1] === slug) {
      if (segs[segs.length - 1].toLowerCase() === filenameLower && mod.default) {
        return mod.default;
      }
    }
  }
  return null;
}

// ── Selected work cards ───────────────────────────────────────
const selectedCards = sortedSelected.map(e => ({
  slug:      e.data.slug,
  title:     e.data.title,
  label:     e.data.label,
  sublabel:  e.data.sublabel,
  isGallery: e.data.isGallery ?? false,
  linkTo:    e.data.linkTo ?? null,
  cover: e.data.seriesSlug
    ? resolveCover(e.data.seriesSlug, e.data.coverImage, seriesCovers, 'series')
    : resolveCover(e.data.slug, e.data.coverImage, selectedCovers, 'selected-works'),
}));

// ── Project cards — fixed display order ───────────────────────
const PROJECT_ORDER = [
  'milkshake-collective',
  'third-eye',
  'uber-brief',
  'sw-reveal',
  'the-residency-airbnb',
  'oof-campaign-omnicom',
  'adidas-avirex',
] as const;

// Sub-labels and portrait flag per project slug
const PROJECT_META: Record<string, { sub: string; portrait: boolean; imgPos: string }> = {
  'milkshake-collective':   { sub: 'Volume I',                portrait: false, imgPos: 'center top'    },
  'third-eye':              { sub: '× Takeout Popup',         portrait: false, imgPos: 'center top'    },
  'uber-brief':             { sub: 'Robots Take Over Philly', portrait: false, imgPos: 'center center' },
  'sw-reveal':              { sub: 'Fordham University',      portrait: false, imgPos: 'center top'    },
  'the-residency-airbnb':   { sub: '× Airbnb',               portrait: false, imgPos: 'center top'    },
  'oof-campaign-omnicom':   { sub: '× Omnicom Health',        portrait: false, imgPos: 'center top'    },
  'adidas-avirex':          { sub: 'adidas × Avirex',         portrait: false, imgPos: 'center center' },
};

const collectionCards = collectionsFromSelected.map(e => ({
  slug:     e.data.slug,
  title:    e.data.title,
  href:     `/work/${e.data.slug}`,
  cover:    resolveCover(e.data.slug, e.data.coverImage, selectedCovers, 'selected-works'),
  sub:      PROJECT_META[e.data.slug]?.sub ?? '',
  portrait: PROJECT_META[e.data.slug]?.portrait ?? false,
  imgPos:   PROJECT_META[e.data.slug]?.imgPos ?? 'center top',
}));

const projectCards = projects.map(e => ({
  slug:     e.data.slug,
  title:    e.data.title,
  href:     `/projects/${e.data.slug}`,
  cover:    resolveCover(e.data.slug, e.data.coverImage, projectCovers, 'projects'),
  sub:      PROJECT_META[e.data.slug]?.sub ?? '',
  portrait: PROJECT_META[e.data.slug]?.portrait ?? false,
  imgPos:   PROJECT_META[e.data.slug]?.imgPos ?? 'center top',
}));

// Merge pool, then order by PROJECT_ORDER
const allProjectPool = [...collectionCards, ...projectCards];
const orderedProjectCards = PROJECT_ORDER
  .map(slug => allProjectPool.find(c => c.slug === slug))
  .filter((c): c is NonNullable<typeof c> => c !== undefined);
---

<Layout
  title="Work"
  description="Photography and creative direction by Adeyinka Maddy."
>

<!-- ═══════════════════════════════════════════════════════════
     PAGE HEADER
════════════════════════════════════════════════════════════ -->
<section class="page-header">
  <div class="header-inner">
    <span class="header-label">Work</span>
  </div>
  <div class="header-rule" aria-hidden="true"></div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     FILTER BAR — Projects first (default)
════════════════════════════════════════════════════════════ -->
<div class="filter-bar" role="navigation" aria-label="Filter work">
  <button class="filter-btn" data-filter="projects" aria-pressed="true">
    Projects
  </button>
  <span class="filter-sep" aria-hidden="true">/</span>
  <button class="filter-btn" data-filter="selected" aria-pressed="false">
    Selected Work
  </button>
</div>


<!-- ═══════════════════════════════════════════════════════════
     PROJECTS GRID — default visible
     Large 2-column cards with title overlay on hover.
════════════════════════════════════════════════════════════ -->
<section
  class="grid-section"
  id="grid-projects"
  aria-label="Projects"
  aria-live="polite"
>
  <div class="work-grid work-grid--projects">
    {orderedProjectCards.map(({ slug, title, href, cover, sub, portrait, imgPos }, i) => (
      <figure class="work-item work-item--linked" aria-label={title}>
        <a href={href} class="item-inner" tabindex="0">
          <div class="item-img-wrap">
            {cover ? (
              <Image
                src={cover}
                alt={title}
                class="item-img"
                loading={i < 2 ? 'eager' : 'lazy'}
                widths={[800, 1200, 1800, 2400]}
                sizes="(max-width: 767px) 100vw, 90vw"
                style={`object-position: ${imgPos}`}
              />
            ) : (
              <div class="item-placeholder" aria-hidden="true"></div>
            )}
            <div class="item-overlay" aria-hidden="true">
              <span class="overlay-title">{title}</span>
            </div>
          </div>
        </a>
      </figure>
    ))}
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     SELECTED WORK GRID — hidden by default
     Masonry of photos; isGallery items are clickable.
════════════════════════════════════════════════════════════ -->
<section
  class="grid-section"
  id="grid-selected"
  aria-label="Selected work"
  aria-live="polite"
  hidden
>
  <div class="work-grid">
    {selectedCards.map(({ slug, title, label, sublabel, isGallery, linkTo, cover }, i) => (
      <figure
        class:list={['work-item', isGallery ? 'work-item--gallery' : 'work-item--static']}
        aria-label={title}
      >
        {isGallery ? (
          <a href={linkTo ?? `/work/${slug}`} class="item-inner" tabindex="0" aria-label={title}>
            <div class:list={['item-img-wrap', { 'has-label': Boolean(label || sublabel) }]}>
              {cover ? (
                <Image
                  src={cover}
                  alt={title}
                  class="item-img"
                  loading={i < 6 ? 'eager' : 'lazy'}
                  widths={[500, 800, 1100]}
                  sizes="(max-width: 767px) 100vw, 45vw"
                />
              ) : (
                <div class="item-placeholder" aria-hidden="true"></div>
              )}
              {(label || sublabel) && (
                <div class="item-label" aria-hidden="true">
                  {label && <span class="label-name">{label}</span>}
                  {sublabel && <span class="label-sub">{sublabel}</span>}
                </div>
              )}
            </div>
          </a>
        ) : (
          <div class="item-inner">
            <div class:list={['item-img-wrap', { 'has-label': Boolean(label || sublabel) }]}>
              {cover ? (
                <Image
                  src={cover}
                  alt={title}
                  class="item-img"
                  loading={i < 6 ? 'eager' : 'lazy'}
                  widths={[500, 800, 1100]}
                  sizes="(max-width: 767px) 100vw, 45vw"
                />
              ) : (
                <div class="item-placeholder" aria-hidden="true"></div>
              )}
              {(label || sublabel) && (
                <div class="item-label" aria-hidden="true">
                  {label && <span class="label-name">{label}</span>}
                  {sublabel && <span class="label-sub">{sublabel}</span>}
                </div>
              )}
            </div>
          </div>
        )}
      </figure>
    ))}
  </div>
</section>

<div class="page-rest" aria-hidden="true"></div>

</Layout>


<script>
  const buttons  = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const gridSel  = document.getElementById('grid-selected')!;
  const gridProj = document.getElementById('grid-projects')!;

  function switchTab(filter: string) {
    buttons.forEach(b => b.setAttribute('aria-pressed', b.dataset.filter === filter ? 'true' : 'false'));
    if (filter === 'selected') {
      gridSel.removeAttribute('hidden');
      gridProj.setAttribute('hidden', '');
    } else {
      gridSel.setAttribute('hidden', '');
      gridProj.removeAttribute('hidden');
    }
  }

  // Check URL for ?tab=selected on load
  const params = new URLSearchParams(window.location.search);
  if (params.get('tab') === 'selected') {
    switchTab('selected');
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      switchTab(filter);
      // Update URL param without page reload
      const url = new URL(window.location.href);
      if (filter === 'selected') {
        url.searchParams.set('tab', 'selected');
      } else {
        url.searchParams.delete('tab');
      }
      history.replaceState({}, '', url.toString());
    });
  });
</script>


<style>

/* ── PAGE HEADER ───────────────────────────────────────────── */

.page-header {
  padding: clamp(8rem, 14vw, 14rem) 2.25rem 0;
}

.header-inner {
  margin-bottom: 1.25rem;
}

.header-label {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(3rem, 8vw, 7.5rem);
  line-height: 1;
  letter-spacing: -0.025em;
  color: #fff;
}

.header-rule {
  height: 1px;
  background: rgba(255, 255, 255, 0.08);
  margin-bottom: clamp(2rem, 4vw, 4rem);
}


/* ── FILTER BAR ────────────────────────────────────────────── */

.filter-bar {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  padding: 0 2.25rem clamp(2.5rem, 4vw, 4rem);
}

.filter-btn {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5625rem;
  letter-spacing: 0.42em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.55);
  padding-left: 0.42em;
  background: none;
  border: none;
  cursor: pointer;
  transition: color 0.18s ease;
  padding-top: 0;
  padding-bottom: 0;
}

.filter-btn:hover {
  color: rgba(255, 255, 255, 0.7);
}

.filter-btn[aria-pressed="true"] {
  color: rgba(255, 255, 255, 0.95);
}

.filter-sep {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.45rem;
  color: rgba(255, 255, 255, 0.28);
}


/* ── GRID SECTION ──────────────────────────────────────────── */

.grid-section {
  padding: 0 2.25rem;
}


/* ── SELECTED WORK — masonry ────────────────────────────────── */

.work-grid {
  columns: 1;
  column-gap: clamp(1rem, 2vw, 2rem);
}

@media (min-width: 640px) {
  .work-grid { columns: 2; }
}

@media (min-width: 1200px) {
  .work-grid { columns: 3; }
}

.work-item {
  break-inside: avoid;
  margin: 0;
  padding-bottom: clamp(1rem, 2vw, 2rem);
  display: block;
}


/* ── PROJECTS — vertical stack, 3:2 landscape ──────────────── */

.work-grid--projects {
  columns: unset;
  display: flex;
  flex-direction: column;
  gap: clamp(4.5rem, 9vw, 11rem);
}

.work-grid--projects .work-item {
  padding-bottom: 0;
  break-inside: unset;
}

/* 3:2 landscape — default */
.work-grid--projects .item-img-wrap {
  aspect-ratio: 3 / 2;
}


.work-grid--projects .item-img {
  height: 100%;
  object-fit: cover;
}


/* ── Shared image wrapper ── */

.item-inner {
  display: block;
}

.item-img-wrap {
  position: relative;
  overflow: hidden;
  display: block;
  background: #0a0a0a;
}

.item-img {
  display: block;
  width: 100%;
  height: auto;
  transition: transform 2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.item-img-wrap:hover .item-img {
  transform: scale(1.018);
}

.item-placeholder {
  width: 100%;
  aspect-ratio: 2 / 3;
  background: #111;
}


/* ── Hover label (Selected Work) ── */

.item-img-wrap.has-label::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.52) 0%,
    rgba(0, 0, 0, 0.12) 35%,
    transparent 58%
  );
  opacity: 0;
  transition: opacity 0.28s ease;
  pointer-events: none;
}

.item-img-wrap.has-label:hover::after {
  opacity: 1;
}

.item-label {
  position: absolute;
  bottom: 1.125rem;
  right: 1.25rem;
  text-align: right;
  z-index: 2;
  opacity: 0;
  transition: opacity 0.28s ease;
  pointer-events: none;
}

.item-img-wrap:hover .item-label {
  opacity: 1;
}

.label-name {
  display: block;
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.3;
}

.label-sub {
  display: block;
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.65);
  padding-left: 0.3em;
  margin-top: 0.3rem;
}


/* ── Projects overlay ── */

.work-item--linked .item-img {
  transition: transform 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.item-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.74) 0%,
    rgba(0, 0, 0, 0.08) 40%,
    transparent 65%
  );
  display: flex;
  align-items: flex-end;
  padding: clamp(1.25rem, 2.5vw, 2.25rem);
  opacity: 0;
  transition: opacity 0.32s ease;
  pointer-events: none;
  z-index: 3;
}

.item-inner:hover .item-overlay {
  opacity: 1;
}

.item-inner:hover .item-img {
  transform: scale(1.025);
}

.overlay-text {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.overlay-sub {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5rem;
  letter-spacing: 0.44em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.62);
  padding-left: 0.44em;
  line-height: 1;
}

.overlay-title {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.375rem, 2.8vw, 2.5rem);
  line-height: 1.05;
  color: #fff;
  letter-spacing: -0.01em;
}


/* ── PAGE REST ─────────────────────────────────────────────── */

.page-rest {
  height: clamp(6rem, 10vw, 12rem);
}


/* ── MOBILE ─────────────────────────────────────────────────── */

@media (max-width: 767px) {
  .page-header  { padding-inline: 1.25rem; }
  .filter-bar   { padding-inline: 1.25rem; gap: 1rem; }
  .grid-section { padding-inline: 1.25rem; }

  .work-grid--projects {
    gap: clamp(3rem, 10vw, 5rem);
  }
}

</style>
