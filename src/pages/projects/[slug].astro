---
/**
 * Project detail page — /projects/[slug]
 *
 * Layout references:
 *   morganpilcher  — generous spacing, unhurried editorial pace
 *   henryschwabe   — confident metadata, institutional weight
 *   alexgeddes     — image-dominant sequence, highlighted breaks
 *
 * Sections:
 *   1. Hero         — full-bleed cover image, title + tag overlaid
 *   2. Metadata bar — client / role / year / location
 *   3. Narrative    — rendered markdown (role, insight, problem, solution)
 *   4. Embed        — videoEmbed or linkedinEmbed iframe if present
 *   5. External CTA — "View Full Project" button if externalUrl present
 *   6. Image sequence — remaining project images (if any)
 */
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// ── Static paths ──────────────────────────────────────────────
export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  return allProjects.map(entry => ({
    params: { slug: entry.data.slug },
    props:  { entry },
  }));
}

const { entry } = Astro.props;

// ── Rendered body ─────────────────────────────────────────────
const { Content } = await render(entry);

// ── Image resolution ──────────────────────────────────────────
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  [
    '/src/content/projects/*/media/*.jpg',
    '/src/content/projects/*/media/*.JPG',
    '/src/content/projects/*/media/*.jpeg',
    '/src/content/projects/*/media/*.JPEG',
    '/src/content/projects/*/media/*.webp',
    '/src/content/projects/*/media/*.WEBP',
    '/src/content/projects/*/media/*.png',
    '/src/content/projects/*/media/*.PNG',
  ],
  { eager: true }
);

const projectDir = entry.id.split('/')[0];

const mediaMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allImages)) {
  const segs  = path.split('/');
  const idx   = segs.indexOf('projects');
  if (idx !== -1 && segs[idx + 1] === projectDir && mod.default) {
    mediaMap[segs[segs.length - 1]] = mod.default;
  }
}

// Cover — resolved from coverImage frontmatter
const coverFilename   = entry.data.coverImage.split('/').pop() ?? '';
const heroImage       = mediaMap[coverFilename] ?? null;

// Image sequence — imageOrder drives order; fall back to sorted filenames
// excluding the cover so it doesn't repeat.
const order       = entry.data.imageOrder ?? Object.keys(mediaMap).sort();
const highlighted = new Set(entry.data.highlightedImages ?? []);

const sequenceImages = order
  .filter(f => f !== coverFilename)          // cover is already the hero
  .map(f => ({ filename: f, src: mediaMap[f], highlighted: highlighted.has(f) }))
  .filter(img => Boolean(img.src));

// ── Metadata ──────────────────────────────────────────────────
const year = entry.data.date.getFullYear();
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
>

<!-- ═══════════════════════════════════════════════════════════
     HERO — full-bleed cover, 80svh.
     Shorter than series (80 vs 100) — projects feel more
     purposeful, less meditative.
════════════════════════════════════════════════════════════ -->
<section class="hero" aria-label={`${entry.data.title} — cover`}>
  {heroImage ? (
    <Image
      src={heroImage}
      alt={`${entry.data.title} — cover`}
      class="hero-img"
      loading="eager"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
    />
  ) : (
    <div class="hero-placeholder" aria-hidden="true"></div>
  )}

  <div class="hero-label">
    <div class="hero-meta">
      {entry.data.tags.map(tag => (
        <span class="meta-tag">{tag}</span>
      ))}
      <span class="meta-dot" aria-hidden="true">/</span>
      <span class="meta-year">{year}</span>
    </div>
    <h1 class="hero-title">{entry.data.title}</h1>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     METADATA BAR
     Client / Role / Location — small tracked uppercase.
     henryschwabe institutional register.
════════════════════════════════════════════════════════════ -->
<div class="meta-bar" aria-label="Project information">
  {entry.data.client && (
    <div class="meta-item">
      <span class="meta-key">Client</span>
      <span class="meta-val">{entry.data.client}</span>
    </div>
  )}
  {entry.data.role && (
    <div class="meta-item">
      <span class="meta-key">Role</span>
      <span class="meta-val">{entry.data.role}</span>
    </div>
  )}
  {entry.data.location && (
    <div class="meta-item">
      <span class="meta-key">Location</span>
      <span class="meta-val">{entry.data.location}</span>
    </div>
  )}
  <div class="meta-item">
    <span class="meta-key">Year</span>
    <span class="meta-val">{year}</span>
  </div>
</div>


<!-- ═══════════════════════════════════════════════════════════
     NARRATIVE — rendered markdown body.
     The **key:** bold pattern in the markdown (My role:,
     Insight:, Problem:, Solution:) is styled to read like
     a case-study brief — clean, structured, confident.
════════════════════════════════════════════════════════════ -->
<section class="narrative" aria-label="Project narrative">
  <div class="narrative-body">
    <Content />
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     EMBED — video or LinkedIn iframe.
     Only one will be present per project.
     Wrapped in a responsive container with a subtle border.
════════════════════════════════════════════════════════════ -->
{(entry.data.videoEmbed || entry.data.linkedinEmbed) && (
  <section class="embed-section" aria-label="Project media embed">
    <div class="embed-wrap">
      {entry.data.videoEmbed && (
        <div
          class="embed-container embed-video"
          set:html={entry.data.videoEmbed}
        />
      )}
      {entry.data.linkedinEmbed && (
        <div
          class="embed-container embed-linkedin"
          set:html={entry.data.linkedinEmbed}
        />
      )}
    </div>
  </section>
)}


<!-- ═══════════════════════════════════════════════════════════
     EXTERNAL CTA
     If the project lives on its own site, surface it here.
     Full-width centered button — the punctuation mark after
     the narrative.
════════════════════════════════════════════════════════════ -->
{entry.data.externalUrl && (
  <section class="cta-section" aria-label="View full project">
    <a
      href={entry.data.externalUrl}
      class="cta-link"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`View full project: ${entry.data.title}`}
    >
      <span class="cta-label">View Full Project</span>
      <span class="cta-arrow" aria-hidden="true">&#x2192;</span>
    </a>
    <div class="cta-url" aria-hidden="true">{entry.data.externalUrl.replace(/^https?:\/\//, '')}</div>
  </section>
)}


<!-- ═══════════════════════════════════════════════════════════
     IMAGE SEQUENCE
     Same rhythm as series/[slug] — regular frames centered
     at 88vw; highlighted frames full-bleed with extra air.
════════════════════════════════════════════════════════════ -->
{sequenceImages.length > 0 && (
  <section class="sequence" aria-label="Project images">
    {sequenceImages.map((img, i) => (
      <figure
        class:list={['frame', { 'is-highlight': img.highlighted }]}
        aria-label={`${entry.data.title} — image ${i + 1} of ${sequenceImages.length}`}
      >
        <Image
          src={img.src}
          alt={`${entry.data.title}${img.highlighted ? ' — featured' : ''}`}
          class="seq-img"
          loading="lazy"
          widths={img.highlighted ? [1200, 1800, 2400, 3200] : [800, 1400, 2000]}
          sizes={img.highlighted ? '100vw' : '(max-width: 767px) 100vw, 88vw'}
        />
      </figure>
    ))}
  </section>
)}

<div class="page-rest" aria-hidden="true"></div>

</Layout>


<style>

/* ── HERO ──────────────────────────────────────────────────── */

.hero {
  position: relative;
  height: 80svh;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.hero-placeholder {
  width: 100%;
  height: 100%;
  background: #0d0d0d;
}

.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.78) 0%,
    rgba(0, 0, 0, 0.1) 40%,
    transparent 68%
  );
  pointer-events: none;
}

.hero-label {
  position: absolute;
  bottom: 0;
  inset-inline: 0;
  padding: 2.5rem 2.25rem 3rem;
  z-index: 10;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.meta-tag,
.meta-year {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5625rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.5);
  padding-left: 0.4em;
}

.meta-dot {
  color: rgba(255, 255, 255, 0.22);
  font-size: 0.5rem;
}

.hero-title {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(2.5rem, 6vw, 7.5rem);
  line-height: 0.95;
  letter-spacing: -0.025em;
  color: #fff;
  max-width: 900px;
}


/* ── METADATA BAR ──────────────────────────────────────────── */

.meta-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  margin: 0 2.25rem;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 3rem) clamp(1.5rem, 3vw, 2.5rem) 0;
  margin-right: clamp(1.5rem, 3vw, 3rem);
  border-right: 1px solid rgba(255, 255, 255, 0.07);
  /* Last item: no right border, no right margin */
}

.meta-item:last-child {
  border-right: none;
}

.meta-key {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.4375rem;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.22);
  padding-left: 0.5em;
}

.meta-val {
  font-family: 'Times New Roman', Times, serif;
  font-size: clamp(0.75rem, 1vw, 0.9375rem);
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.3;
}


/* ── NARRATIVE ─────────────────────────────────────────────── */

.narrative {
  display: flex;
  justify-content: center;
  padding: clamp(5rem, 8vw, 10rem) 2.25rem clamp(4rem, 6vw, 8rem);
}

.narrative-body {
  max-width: 640px;
  width: 100%;
}

/* Hide placeholder heading */
.narrative-body :global(h1),
.narrative-body :global(h2),
.narrative-body :global(h3) {
  display: none;
}

/* Body paragraphs */
.narrative-body :global(p) {
  font-family: 'Times New Roman', Times, serif;
  font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
  line-height: 1.85;
  color: rgba(255, 255, 255, 0.62);
  margin-bottom: 1.5rem;
}

.narrative-body :global(p:last-child) {
  margin-bottom: 0;
}

/*
  Bold labels — **My role:**, **Insight:**, etc.
  Slightly brighter and slightly larger so the structure reads.
*/
.narrative-body :global(p strong) {
  font-weight: 600;
  color: rgba(255, 255, 255, 0.88);
  font-size: 1.0125em;
}

/* Inline links (e.g. "View Full Project Website") */
.narrative-body :global(a) {
  color: rgba(255, 255, 255, 0.7);
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  transition: color 0.18s ease, border-color 0.18s ease;
  padding-bottom: 0.05em;
}

.narrative-body :global(a:hover) {
  color: #fff;
  border-color: rgba(255, 255, 255, 0.6);
}


/* ── EMBED ─────────────────────────────────────────────────── */

.embed-section {
  display: flex;
  justify-content: center;
  padding: 0 2.25rem clamp(4rem, 6vw, 8rem);
}

.embed-wrap {
  max-width: 640px;
  width: 100%;
}

/* Generic iframe container */
.embed-container {
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 2px;
  overflow: hidden;
  background: #080808;
}

/* Video embeds — 16:9 */
.embed-video {
  position: relative;
  padding-top: 56.25%; /* 16:9 */
}

.embed-video :global(iframe) {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

/* LinkedIn embeds — fixed height, centered */
.embed-linkedin {
  display: flex;
  justify-content: center;
  padding: 1.5rem;
}

.embed-linkedin :global(iframe) {
  max-width: 100%;
  border: none;
  display: block;
}


/* ── EXTERNAL CTA ──────────────────────────────────────────── */

.cta-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: clamp(2rem, 4vw, 4rem) 2.25rem clamp(4rem, 6vw, 8rem);
  gap: 1rem;
}

.cta-link {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.375rem, 2.5vw, 2.25rem);
  color: rgba(255, 255, 255, 0.82);
  letter-spacing: -0.01em;
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  padding-bottom: 0.1em;
  transition: color 0.2s ease, gap 0.25s ease, border-color 0.2s ease;
}

.cta-link:hover {
  color: #fff;
  gap: 1.5rem;
  border-color: rgba(255, 255, 255, 0.55);
}

.cta-arrow {
  font-style: normal;
  font-size: 1.1em;
  transition: transform 0.25s ease;
}

.cta-link:hover .cta-arrow {
  transform: translateX(4px);
}

.cta-url {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5rem;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.2);
  padding-left: 0.35em;
}


/* ── IMAGE SEQUENCE ────────────────────────────────────────── */

.sequence {
  padding: 0;
}

.frame {
  margin: 0;
  padding-bottom: clamp(4rem, 6vw, 8rem);
  display: flex;
  justify-content: center;
}

.frame .seq-img {
  display: block;
  width: min(88vw, 1200px);
  height: auto;
}

.frame.is-highlight {
  padding-top: clamp(4rem, 6vw, 8rem);
  padding-bottom: clamp(7rem, 10vw, 14rem);
  width: 100vw;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
}

.frame.is-highlight .seq-img {
  width: 100%;
  max-width: none;
  height: auto;
}


/* ── PAGE REST ─────────────────────────────────────────────── */

.page-rest {
  height: clamp(5rem, 8vw, 10rem);
}


/* ── MOBILE ─────────────────────────────────────────────────── */

@media (max-width: 639px) {
  .hero-label {
    padding: 2rem 1.25rem 2.5rem;
  }

  .meta-bar {
    margin-inline: 1.25rem;
    flex-direction: column;
    gap: 0;
  }

  .meta-item {
    flex-direction: row;
    justify-content: space-between;
    align-items: baseline;
    padding: 1rem 0;
    margin-right: 0;
    border-right: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .meta-item:last-child {
    border-bottom: none;
  }

  .narrative {
    padding-inline: 1.25rem;
  }

  .embed-section {
    padding-inline: 1.25rem;
  }

  .cta-section {
    padding-inline: 1.25rem;
  }

  .frame .seq-img {
    width: 100vw;
  }
}

</style>
