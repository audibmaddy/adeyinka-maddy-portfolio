---
/**
 * Project detail page — /projects/[slug]
 *
 * Two layouts depending on content:
 *
 *   Video-first (vimeoId present):
 *     1. Compact title header
 *     2. Theater video — big, centered, responsive 16:9
 *     3. Metadata bar (client / role / location / year)
 *     4. Scope paragraph
 *     5. Image sequence (if any)
 *
 *   Image-first (no vimeoId):
 *     1. Full-bleed hero image
 *     2. Metadata bar
 *     3. Narrative (rendered markdown)
 *     4. Embed (videoEmbed / linkedinEmbed) if present
 *     5. External CTA if present
 *     6. Image sequence (if any)
 */
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// ── Static paths ──────────────────────────────────────────────
export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  return allProjects.map(entry => ({
    params: { slug: entry.data.slug },
    props:  { entry },
  }));
}

const { entry } = Astro.props;

// ── Rendered body ─────────────────────────────────────────────
const { Content } = await render(entry);

// ── Image resolution ──────────────────────────────────────────
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  [
    '/src/content/projects/*/media/*.jpg',
    '/src/content/projects/*/media/*.JPG',
    '/src/content/projects/*/media/*.jpeg',
    '/src/content/projects/*/media/*.JPEG',
    '/src/content/projects/*/media/*.webp',
    '/src/content/projects/*/media/*.WEBP',
    '/src/content/projects/*/media/*.png',
    '/src/content/projects/*/media/*.PNG',
  ],
  { eager: true }
);

const projectDir = entry.id.split('/')[0];

const mediaMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allImages)) {
  const segs = path.split('/');
  const idx  = segs.indexOf('projects');
  if (idx !== -1 && segs[idx + 1] === projectDir && mod.default) {
    mediaMap[segs[segs.length - 1]] = mod.default;
  }
}

const coverFilename = entry.data.coverImage.split('/').pop() ?? '';
const heroImage     = mediaMap[coverFilename] ?? null;

const order       = entry.data.imageOrder ?? Object.keys(mediaMap).sort();
const highlighted = new Set(entry.data.highlightedImages ?? []);

const sequenceImages = order
  .filter(f => f !== coverFilename)
  .map(f => ({ filename: f, src: mediaMap[f], highlighted: highlighted.has(f) }))
  .filter(img => Boolean(img.src));

const year        = entry.data.date.getFullYear();
const isVideoFirst = Boolean(entry.data.vimeoId);
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
>

{isVideoFirst ? (

  <!-- ═══════════════════════════════════════════════════════════
       VIDEO-FIRST LAYOUT
  ════════════════════════════════════════════════════════════ -->

  <>
    <!-- Compact title header -->
    <header class="vf-header">
      <div class="vf-meta">
        {entry.data.tags.map(tag => (
          <span class="meta-tag">{tag}</span>
        ))}
        <span class="meta-dot" aria-hidden="true">/</span>
        <span class="meta-year">{year}</span>
      </div>
      <h1 class="vf-title">{entry.data.title}</h1>
    </header>

    <!-- Theater video -->
    <section class="theater" aria-label={`${entry.data.title} — video`}>
      <div class="theater-wrap">
        <div class="theater-ratio">
          <iframe
            src={`https://player.vimeo.com/video/${entry.data.vimeoId}?badge=0&autopause=0&player_id=0&app_id=58479`}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
            class="theater-iframe"
            title={entry.data.title}
          ></iframe>
        </div>
      </div>
    </section>

    <!-- Metadata bar -->
    <div class="meta-bar" aria-label="Project information">
      {entry.data.client && (
        <div class="meta-item">
          <span class="meta-key">Client</span>
          <span class="meta-val">{entry.data.client}</span>
        </div>
      )}
      {entry.data.role && (
        <div class="meta-item">
          <span class="meta-key">Role</span>
          <span class="meta-val">{entry.data.role}</span>
        </div>
      )}
      {entry.data.location && (
        <div class="meta-item">
          <span class="meta-key">Location</span>
          <span class="meta-val">{entry.data.location}</span>
        </div>
      )}
      <div class="meta-item">
        <span class="meta-key">Year</span>
        <span class="meta-val">{year}</span>
      </div>
    </div>

    <!-- Scope -->
    {entry.data.scope && (
      <section class="scope-section" aria-label="Project scope">
        <div class="scope-body">
          <span class="scope-label">Scope</span>
          <p class="scope-text">{entry.data.scope}</p>
        </div>
      </section>
    )}
  </>

) : (

  <!-- ═══════════════════════════════════════════════════════════
       IMAGE-FIRST LAYOUT (existing projects)
  ════════════════════════════════════════════════════════════ -->

  <>
    <!-- Full-bleed hero -->
    <section class="hero" aria-label={`${entry.data.title} — cover`}>
      {heroImage ? (
        <Image
          src={heroImage}
          alt={`${entry.data.title} — cover`}
          class="hero-img"
          loading="eager"
          widths={[1200, 1800, 2400]}
          sizes="100vw"
        />
      ) : (
        <div class="hero-placeholder" aria-hidden="true"></div>
      )}
      <div class="hero-label">
        <div class="hero-meta">
          {entry.data.tags.map(tag => (
            <span class="meta-tag">{tag}</span>
          ))}
          <span class="meta-dot" aria-hidden="true">/</span>
          <span class="meta-year">{year}</span>
        </div>
        <h1 class="hero-title">{entry.data.title}</h1>
      </div>
    </section>

    <!-- Metadata bar -->
    <div class="meta-bar" aria-label="Project information">
      {entry.data.client && (
        <div class="meta-item">
          <span class="meta-key">Client</span>
          <span class="meta-val">{entry.data.client}</span>
        </div>
      )}
      {entry.data.role && (
        <div class="meta-item">
          <span class="meta-key">Role</span>
          <span class="meta-val">{entry.data.role}</span>
        </div>
      )}
      {entry.data.location && (
        <div class="meta-item">
          <span class="meta-key">Location</span>
          <span class="meta-val">{entry.data.location}</span>
        </div>
      )}
      <div class="meta-item">
        <span class="meta-key">Year</span>
        <span class="meta-val">{year}</span>
      </div>
    </div>

    <!-- Narrative -->
    <section class="narrative" aria-label="Project narrative">
      <div class="narrative-body">
        <Content />
      </div>
    </section>

    <!-- Embed (video or LinkedIn) -->
    {(entry.data.videoEmbed || entry.data.linkedinEmbed) && (
      <section class="embed-section" aria-label="Project media embed">
        <div class="embed-wrap">
          {entry.data.videoEmbed && (
            <div class="embed-container embed-video" set:html={entry.data.videoEmbed} />
          )}
          {entry.data.linkedinEmbed && (
            <div class="embed-container embed-linkedin" set:html={entry.data.linkedinEmbed} />
          )}
        </div>
      </section>
    )}

    <!-- External CTA -->
    {entry.data.externalUrl && (
      <section class="cta-section" aria-label="View full project">
        <a
          href={entry.data.externalUrl}
          class="cta-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="cta-label">View Full Project</span>
          <span class="cta-arrow" aria-hidden="true">&#x2192;</span>
        </a>
        <div class="cta-url" aria-hidden="true">{entry.data.externalUrl.replace(/^https?:\/\//, '')}</div>
      </section>
    )}
  </>

)}


<!-- Image sequence (shared by both layouts) -->
{sequenceImages.length > 0 && (
  <section class="sequence" aria-label="Project images">
    {sequenceImages.map((img, i) => (
      <figure
        class:list={['frame', { 'is-highlight': img.highlighted }]}
        aria-label={`${entry.data.title} — image ${i + 1} of ${sequenceImages.length}`}
      >
        <Image
          src={img.src}
          alt={`${entry.data.title}${img.highlighted ? ' — featured' : ''}`}
          class="seq-img"
          loading="lazy"
          widths={img.highlighted ? [1200, 1800, 2400, 3200] : [800, 1400, 2000]}
          sizes={img.highlighted ? '100vw' : '(max-width: 767px) 100vw, 88vw'}
        />
      </figure>
    ))}
  </section>
)}

<div class="page-rest" aria-hidden="true"></div>

</Layout>


<style>

/* ── VIDEO-FIRST: COMPACT HEADER ───────────────────────────── */

.vf-header {
  padding: clamp(9rem, 15vw, 15rem) 2.25rem clamp(2.5rem, 4vw, 4rem);
}

.vf-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.25rem;
}

.vf-title {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(2.5rem, 7vw, 8rem);
  line-height: 0.93;
  letter-spacing: -0.025em;
  color: #fff;
}


/* ── VIDEO-FIRST: THEATER EMBED ────────────────────────────── */

.theater {
  padding: 0 2.25rem clamp(3rem, 5vw, 6rem);
}

.theater-wrap {
  /* Wide theater — fills up to 1200px, stays within viewport */
  width: min(100%, 1200px);
  margin: 0 auto;
}

.theater-ratio {
  position: relative;
  padding-top: 56.25%; /* 16:9 */
  background: #000;
  border-radius: 2px;
  overflow: hidden;
}

.theater-iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}


/* ── VIDEO-FIRST: SCOPE ─────────────────────────────────────── */

.scope-section {
  display: flex;
  justify-content: center;
  padding: clamp(3rem, 5vw, 6rem) 2.25rem clamp(4rem, 7vw, 8rem);
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.scope-body {
  max-width: 700px;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.scope-label {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5rem;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.45);
  padding-left: 0.5em;
}

.scope-text {
  font-family: 'Times New Roman', Times, serif;
  font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
  line-height: 1.88;
  color: rgba(255, 255, 255, 0.6);
}


/* ── IMAGE-FIRST: HERO ─────────────────────────────────────── */

.hero {
  position: relative;
  height: 80svh;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.hero-placeholder {
  width: 100%;
  height: 100%;
  background: #0d0d0d;
}

.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.78) 0%,
    rgba(0, 0, 0, 0.1) 40%,
    transparent 68%
  );
  pointer-events: none;
}

.hero-label {
  position: absolute;
  bottom: 0;
  inset-inline: 0;
  padding: 2.5rem 2.25rem 3rem;
  z-index: 10;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.hero-title {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(2.5rem, 6vw, 7.5rem);
  line-height: 0.95;
  letter-spacing: -0.025em;
  color: #fff;
  max-width: 900px;
}


/* ── SHARED META ───────────────────────────────────────────── */

.meta-tag,
.meta-year {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5625rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.68);
  padding-left: 0.4em;
}

.meta-dot {
  color: rgba(255, 255, 255, 0.35);
  font-size: 0.5rem;
}

.meta-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  border-top: 1px solid rgba(255, 255, 255, 0.07);
  border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  margin: 0 2.25rem;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 3rem) clamp(1.5rem, 3vw, 2.5rem) 0;
  margin-right: clamp(1.5rem, 3vw, 3rem);
  border-right: 1px solid rgba(255, 255, 255, 0.07);
}

.meta-item:last-child {
  border-right: none;
}

.meta-key {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.4375rem;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.45);
  padding-left: 0.5em;
}

.meta-val {
  font-family: 'Times New Roman', Times, serif;
  font-size: clamp(0.75rem, 1vw, 0.9375rem);
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.3;
}


/* ── IMAGE-FIRST: NARRATIVE ────────────────────────────────── */

.narrative {
  display: flex;
  justify-content: center;
  padding: clamp(5rem, 8vw, 10rem) 2.25rem clamp(4rem, 6vw, 8rem);
}

.narrative-body {
  max-width: 640px;
  width: 100%;
}

.narrative-body :global(h1),
.narrative-body :global(h2),
.narrative-body :global(h3) {
  display: none;
}

.narrative-body :global(p) {
  font-family: 'Times New Roman', Times, serif;
  font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
  line-height: 1.85;
  color: rgba(255, 255, 255, 0.62);
  margin-bottom: 1.5rem;
}

.narrative-body :global(p:last-child) {
  margin-bottom: 0;
}

.narrative-body :global(p strong) {
  font-weight: 600;
  color: rgba(255, 255, 255, 0.88);
  font-size: 1.0125em;
}

.narrative-body :global(a) {
  color: rgba(255, 255, 255, 0.7);
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  transition: color 0.18s ease, border-color 0.18s ease;
  padding-bottom: 0.05em;
}

.narrative-body :global(a:hover) {
  color: #fff;
  border-color: rgba(255, 255, 255, 0.6);
}


/* ── IMAGE-FIRST: EMBED ────────────────────────────────────── */

.embed-section {
  display: flex;
  justify-content: center;
  padding: 0 2.25rem clamp(4rem, 6vw, 8rem);
}

.embed-wrap {
  max-width: 640px;
  width: 100%;
}

.embed-container {
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 2px;
  overflow: hidden;
  background: #080808;
}

.embed-video {
  position: relative;
  padding-top: 56.25%;
}

.embed-video :global(iframe) {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

.embed-linkedin {
  display: flex;
  justify-content: center;
  padding: 1.5rem;
}

.embed-linkedin :global(iframe) {
  max-width: 100%;
  border: none;
  display: block;
}


/* ── IMAGE-FIRST: CTA ──────────────────────────────────────── */

.cta-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: clamp(2rem, 4vw, 4rem) 2.25rem clamp(4rem, 6vw, 8rem);
  gap: 1rem;
}

.cta-link {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.375rem, 2.5vw, 2.25rem);
  color: rgba(255, 255, 255, 0.82);
  letter-spacing: -0.01em;
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  padding-bottom: 0.1em;
  transition: color 0.2s ease, gap 0.25s ease, border-color 0.2s ease;
}

.cta-link:hover {
  color: #fff;
  gap: 1.5rem;
  border-color: rgba(255, 255, 255, 0.55);
}

.cta-arrow {
  font-style: normal;
  font-size: 1.1em;
  transition: transform 0.25s ease;
}

.cta-link:hover .cta-arrow {
  transform: translateX(4px);
}

.cta-url {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5rem;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.42);
  padding-left: 0.35em;
}


/* ── IMAGE SEQUENCE ────────────────────────────────────────── */

.sequence {
  padding: 0;
  padding-top: clamp(3rem, 5vw, 6rem);
}

.frame {
  margin: 0;
  padding-bottom: clamp(4rem, 6vw, 8rem);
  display: flex;
  justify-content: center;
}

.frame .seq-img {
  display: block;
  width: min(88vw, 1200px);
  height: auto;
}

.frame.is-highlight {
  padding-top: clamp(4rem, 6vw, 8rem);
  padding-bottom: clamp(7rem, 10vw, 14rem);
  width: 100vw;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
}

.frame.is-highlight .seq-img {
  width: 100%;
  max-width: none;
  height: auto;
}


/* ── PAGE REST ─────────────────────────────────────────────── */

.page-rest {
  height: clamp(5rem, 8vw, 10rem);
}


/* ── MOBILE ─────────────────────────────────────────────────── */

@media (max-width: 639px) {
  .vf-header {
    padding-inline: 1.25rem;
  }

  .theater {
    padding-inline: 0;
  }

  .scope-section {
    padding-inline: 1.25rem;
  }

  .hero-label {
    padding: 2rem 1.25rem 2.5rem;
  }

  .meta-bar {
    margin-inline: 1.25rem;
    flex-direction: column;
    gap: 0;
  }

  .meta-item {
    flex-direction: row;
    justify-content: space-between;
    align-items: baseline;
    padding: 1rem 0;
    margin-right: 0;
    border-right: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .meta-item:last-child {
    border-bottom: none;
  }

  .narrative {
    padding-inline: 1.25rem;
  }

  .embed-section {
    padding-inline: 1.25rem;
  }

  .cta-section {
    padding-inline: 1.25rem;
  }

  .frame .seq-img {
    width: 100vw;
  }
}

</style>
