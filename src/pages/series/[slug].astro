---
/**
 * Series detail page — /series/[slug]
 *
 * Layout references:
 *   alexgeddes/tristanclausen — full-bleed hero, centered artist statement,
 *     image-dominant scroll with featured frames breaking the grid
 *   morganpilcher — generous, consistent spacing between images
 *   henryschwabe — institutional metadata, confident scale
 */
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// ── Static paths ──────────────────────────────────────────────
export async function getStaticPaths() {
  const allSeries = await getCollection('series');
  return allSeries.map(entry => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

// ── Rendered body (artist statement + equipment colophon) ─────
const { Content } = await render(entry);

// ── Image resolution ──────────────────────────────────────────
// Vite eagerly imports every image across all series.
// We filter to this entry's folder using the entry.id path prefix.
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  [
    '/src/content/series/*/media/*.jpg',
    '/src/content/series/*/media/*.JPG',
    '/src/content/series/*/media/*.jpeg',
    '/src/content/series/*/media/*.JPEG',
    '/src/content/series/*/media/*.webp',
    '/src/content/series/*/media/*.WEBP',
    '/src/content/series/*/media/*.png',
    '/src/content/series/*/media/*.PNG',
  ],
  { eager: true }
);

// entry.id shape: "fordham-road/index" — take the directory component
const seriesDir = entry.id.split('/')[0];

// filename → ImageMetadata for this series only
const mediaMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allImages)) {
  const segments = path.split('/');
  const idx = segments.indexOf('series');
  if (idx !== -1 && segments[idx + 1] === seriesDir && mod.default) {
    const filename = segments[segments.length - 1];
    mediaMap[filename] = mod.default;
  }
}

// Order images, annotate highlighted ones
const order      = entry.data.imageOrder ?? Object.keys(mediaMap);
const highlighted = new Set(entry.data.highlightedImages ?? []);

const images = order
  .map(f => ({ filename: f, src: mediaMap[f], highlighted: highlighted.has(f) }))
  .filter(img => Boolean(img.src));

const heroImage     = images[0]?.src;
const sequenceImages = images.slice(1);

// Formatted date
const year = entry.data.date.getFullYear();
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
>

<!-- ═══════════════════════════════════════════════════════════
     HERO — full-bleed cover, 100svh
     Title + metadata overlaid at the bottom.
════════════════════════════════════════════════════════════ -->
<section class="hero" aria-label={`${entry.data.title} — cover`}>
  {heroImage && (
    <Image
      src={heroImage}
      alt={`${entry.data.title} — cover photograph`}
      class="hero-img"
      loading="eager"
      widths={[1200, 1800, 2400]}
      sizes="100vw"
    />
  )}

  <!-- Bottom gradient lives in CSS ::after -->

  <div class="hero-label">
    <div class="hero-meta">
      {entry.data.tags.map(tag => (
        <span class="meta-tag">{tag}</span>
      ))}
      <span class="meta-dot" aria-hidden="true">/</span>
      <span class="meta-year">{year}</span>
    </div>
    <h1 class="hero-title">{entry.data.title}</h1>
    {entry.data.exhibition && (
      <p class="hero-exhibition">{entry.data.exhibition}</p>
    )}
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     ARTIST STATEMENT — centered, alexgeddes reference.
     The rendered markdown includes the narrative paragraphs
     and the equipment colophon (styled as a smaller last-child).
     The placeholder heading "# Full narrative statement…" is
     hidden via CSS.
════════════════════════════════════════════════════════════ -->
<section class="statement" aria-label="Artist statement">
  <div class="statement-body">
    <Content />
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     IMAGE SEQUENCE
     Regular frames: centered at 88 % viewport width.
     Highlighted frames: full-bleed, extra vertical breathing room.
     Spacing rhythm: morganpilcher reference — deliberate, unhurried.
════════════════════════════════════════════════════════════ -->
<section class="sequence" aria-label="Series photographs">
  {sequenceImages.map((img, i) => (
    <figure
      id={img.filename.replace(/\.[^.]+$/, '').toLowerCase()}
      class:list={['frame', { 'is-highlight': img.highlighted }]}
      aria-label={`${entry.data.title} — image ${i + 2} of ${images.length}`}
    >
      <Image
        src={img.src}
        alt={`${entry.data.title}${img.highlighted ? ' — featured image' : ''}`}
        class="seq-img"
        loading="lazy"
        widths={img.highlighted ? [1200, 1800, 2400, 3200] : [800, 1400, 2000]}
        sizes={img.highlighted
          ? '100vw'
          : '(max-width: 767px) 100vw, 88vw'}
      />
    </figure>
  ))}
</section>

<!-- Video at end (if vimeoId present) -->
{entry.data.vimeoId && (
  <section class="series-video" aria-label={`${entry.data.title} — video`}>
    <div class="video-wrap">
      <div class="video-ratio">
        <iframe
          src={`https://player.vimeo.com/video/${entry.data.vimeoId}?badge=0&autopause=0&player_id=0&app_id=58479&loop=1`}
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          class="video-iframe"
          title={entry.data.title}
        ></iframe>
      </div>
    </div>
  </section>
)}

<!-- Generous post-sequence rest before ABM footer -->
<div class="sequence-rest" aria-hidden="true"></div>

</Layout>


<style>

/* ── HERO ──────────────────────────────────────────────────── */

.hero {
  position: relative;
  height: 100svh;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

/* Bottom scrim — makes title readable without obscuring the image */
.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.75) 0%,
    rgba(0, 0, 0, 0.12) 38%,
    transparent 65%
  );
  pointer-events: none;
}

.hero-label {
  position: absolute;
  bottom: 0;
  inset-inline: 0;
  padding: 2.5rem 2.25rem 3rem;
  z-index: 10;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.meta-tag,
.meta-year {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5625rem;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.68);
  padding-left: 0.4em;
}

.meta-dot {
  color: rgba(255, 255, 255, 0.35);
  font-size: 0.5rem;
}

.hero-title {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(2.75rem, 6.5vw, 8rem);
  line-height: 0.95;
  letter-spacing: -0.025em;
  color: #fff;
  max-width: 900px;
}

.hero-exhibition {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5625rem;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.72);
  padding-left: 0.32em;
  margin-top: 1.25rem;
}


/* ── ARTIST STATEMENT ──────────────────────────────────────── */

.statement {
  display: flex;
  justify-content: center;
  /* Generous vertical padding — the text needs space to breathe */
  padding: clamp(6rem, 10vw, 12rem) 2.25rem clamp(5rem, 8vw, 10rem);
}

.statement-body {
  max-width: 600px;
  width: 100%;
}

/*
  Hide the template placeholder heading.
  "# Full narrative statement goes here (Markdown)"
  is not content — it's an editing instruction.
*/
.statement-body :global(h1),
.statement-body :global(h2),
.statement-body :global(h3) {
  display: none;
}

/* Narrative paragraphs */
.statement-body :global(p) {
  font-family: 'Times New Roman', Times, serif;
  font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
  line-height: 1.85;
  color: rgba(255, 255, 255, 0.65);
  margin-bottom: 1.625rem;
}

.statement-body :global(p strong) {
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
}

/*
  Equipment / colophon — the last paragraph.
  "Pentax Zoom 90 WR, Canon Autoboy, Nikon F100…"
  Styled as a discreet footnote.
*/
.statement-body :global(p:last-of-type) {
  font-size: 0.625rem;
  letter-spacing: 0.08em;
  line-height: 2.1;
  color: rgba(255, 255, 255, 0.22);
  margin-top: 4rem;
  margin-bottom: 0;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  padding-top: 1.5rem;
}


/* ── IMAGE SEQUENCE ────────────────────────────────────────── */

.sequence {
  /* Let frames manage their own spacing */
  padding: 0;
}

/* ─ Regular frame ─ */
.frame {
  margin: 0;
  padding-bottom: clamp(4rem, 6vw, 8rem);
  display: flex;
  justify-content: center;
}

.frame .seq-img {
  display: block;
  /* Centered at 88 vw — generous but not full-bleed */
  width: min(88vw, 1200px);
  height: auto;
}

/* ─ Highlighted / featured frame ─
   Full-bleed. Extra vertical silence above and below.
   The "reveal moment" in the scroll — alexgeddes reference.
*/
.frame.is-highlight {
  padding-top: clamp(4rem, 6vw, 8rem);
  padding-bottom: clamp(7rem, 10vw, 14rem);
  /* Allow the image to overflow any container padding */
  width: 100vw;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
}

.frame.is-highlight .seq-img {
  width: 100%;
  max-width: none;
  height: auto;
}

/* ── END VIDEO ─────────────────────────────────────────────── */

.series-video {
  padding: clamp(4rem, 6vw, 8rem) 2.25rem 0;
}

.video-wrap {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
}

.video-ratio {
  position: relative;
  padding-top: 50%; /* matches the embed's native aspect ratio */
  background: #000;
  overflow: hidden;
}

.video-iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

@media (max-width: 639px) {
  .series-video {
    padding-inline: 0;
  }
}


/* Post-sequence rest — morganpilcher meditative finish */
.sequence-rest {
  height: clamp(5rem, 8vw, 10rem);
}


/* ── MOBILE ─────────────────────────────────────────────────── */

@media (max-width: 639px) {
  .hero-label {
    padding: 2rem 1.25rem 2.5rem;
  }

  .statement {
    padding-inline: 1.25rem;
  }

  /* On mobile all regular frames go full-width too */
  .frame .seq-img {
    width: 100vw;
  }
}

</style>
