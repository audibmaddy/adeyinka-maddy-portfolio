---
/**
 * Contact — /contact — redirects to /about
 */
return Astro.redirect('/about', 301);
/**
 * (Original contact page kept below for reference)
 *
 * Minimal. A single invitation to reach out.
 * Real details: phone, email, Instagram, LinkedIn, location.
 * References: michaelclarke (calm, clean), cathydolle (spare)
 */
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Get in touch with Adeyinka Maddy — photographer and project manager based in Queens, NY."
>

<!-- ═══════════════════════════════════════════════════════════
     CONTACT
════════════════════════════════════════════════════════════ -->
<section class="contact-page" aria-label="Contact">

  <div class="contact-header">
    <div class="header-rule" aria-hidden="true"></div>
    <h1 class="contact-title">Get in<br />Touch</h1>
  </div>

  <div class="contact-body">

    <!-- Email -->
    <div class="contact-block">
      <span class="contact-label">Email</span>
      <a
        href="mailto:adeyinkabmaddy@gmail.com"
        class="contact-link contact-link--primary"
        aria-label="Send an email to Adeyinka Maddy"
      >
        adeyinkabmaddy@gmail.com
      </a>
    </div>

    <!-- Phone -->
    <div class="contact-block">
      <span class="contact-label">Phone</span>
      <a
        href="tel:+19163081848"
        class="contact-link contact-link--primary"
        aria-label="Call Adeyinka Maddy"
      >
        916-308-1848
      </a>
    </div>

    <!-- Social links -->
    <div class="contact-block">
      <span class="contact-label">Social</span>
      <div class="contact-socials">
        <a
          href="https://www.instagram.com/audi.abm"
          class="contact-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Adeyinka Maddy on Instagram"
        >
          Instagram
        </a>
        <a
          href="https://www.linkedin.com/in/adeyinka-maddy-62950320b/?skipRedirect=true"
          class="contact-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Adeyinka Maddy on LinkedIn"
        >
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Location -->
    <div class="contact-block">
      <span class="contact-label">Location</span>
      <p class="contact-note">Queens, New York</p>
    </div>

  </div>

</section>

<div class="page-rest" aria-hidden="true"></div>

</Layout>


<style>

/* ── CONTACT PAGE ──────────────────────────────────────────── */

.contact-page {
  padding: clamp(8rem, 14vw, 14rem) 2.25rem 0;
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(4rem, 8vw, 8rem);
}

@media (min-width: 768px) {
  .contact-page {
    grid-template-columns: 1fr 1fr;
    align-items: start;
  }
}


/* ── Header ── */

.header-rule {
  height: 1px;
  background: rgba(255, 255, 255, 0.08);
  margin-bottom: clamp(2.5rem, 4vw, 4rem);
}

.contact-title {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(3.5rem, 10vw, 11rem);
  line-height: 0.92;
  letter-spacing: -0.03em;
  color: #fff;
}


/* ── Body / links ── */

.contact-body {
  display: flex;
  flex-direction: column;
  gap: clamp(2.5rem, 4vw, 4rem);
  padding-top: 0;
}

@media (min-width: 768px) {
  .contact-body {
    padding-top: clamp(3rem, 5vw, 5rem);
  }
}

.contact-block {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.07);
}

.contact-label {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.5rem;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.45);
  padding-left: 0.5em;
}

/* Primary links — email + phone, larger */
.contact-link--primary {
  font-family: 'Instrument Serif', 'Times New Roman', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.125rem, 2.5vw, 2rem);
  line-height: 1.2;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: -0.01em;
  transition: color 0.2s ease;
}

.contact-link--primary:hover {
  color: #fff;
}

/* Social links — smaller, tracked */
.contact-socials {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.contact-link {
  font-family: 'Times New Roman', Times, serif;
  font-size: 0.6875rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.62);
  padding-left: 0.28em;
  transition: color 0.18s ease;
}

.contact-link:hover {
  color: rgba(255, 255, 255, 0.9);
}

.contact-note {
  font-family: 'Times New Roman', Times, serif;
  font-size: clamp(0.8125rem, 1vw, 0.9375rem);
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.62);
}


/* ── PAGE REST ─────────────────────────────────────────────── */

.page-rest {
  height: clamp(6rem, 10vw, 12rem);
}


/* ── MOBILE ─────────────────────────────────────────────────── */

@media (max-width: 639px) {
  .contact-page {
    padding-inline: 1.25rem;
  }
}

</style>
